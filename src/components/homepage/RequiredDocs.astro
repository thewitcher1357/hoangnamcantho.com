---
const documents = [
  {
    number: "1",
    title: "Tên Công ty:",
    description: "Nếu chưa rõ, Hoàng Nam sẽ hỗ trợ tư vấn đặt tên theo phong thủy miễn phí.",
  },
  {
    number: "2",
    title: "Địa chỉ công ty:",
    description: "Chỉ cần địa chỉ rõ ràng, không bắt buộc phải có hợp đồng thuê nhà.",
  },
  {
    number: "3",
    title: "Giấy tờ định danh:",
    description: "Chụp ảnh CCCD và CCCD điện tử trên vneid của các thành viên (Hoàng Nam soạn hồ sơ trước, sau đó đi công chứng chụp lại sau).",
  },
  {
    number: "4",
    title: "Ngành nghề kinh doanh:",
    description: "Xác định 1 ngành chính và các ngành phụ.",
  },
  {
    number: "5",
    title: "Vốn điều lệ:",
    description: "Đăng ký mức vốn cụ thể (Lưu ý mức thuế môn bài: dưới 10 tỷ là 2 triệu/năm, trên 10 tỷ là 3 triệu/năm).",
  },
  {
    number: "6",
    title: "Thông tin liên lạc:",
    description: "Số điện thoại và email công ty (Email có thể bổ sung sau).",
  },
];
---

<section class="bg-gradient-to-r from-primary to-primary-light py-16 md:py-24">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Hồ Sơ Khách Hàng Cần Chuẩn Bị
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-lg leading-8 text-white/90">
        Để tiến hành thủ tục nhanh chóng, quý khách vui lòng cung cấp các thông tin đơn giản sau:
      </p>
    </div>

    <div class="mt-16 grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {documents.map((doc) => (
        <div class="rounded-xl border border-white/10 bg-white/5 p-8 text-white shadow-lg backdrop-blur-sm transition-all duration-300 hover:border-white/20 hover:bg-white/10">
          <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white">
            <span class="text-2xl font-bold text-primary">{doc.number}</span>
          </div>
          <h3 class="mt-6 text-lg font-bold">{doc.title}</h3>
          <p class="mt-2 text-base text-white/80">{doc.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
