---
import { Image } from "astro:assets";
import { siteConfig } from "@/config/site";
import heroBannerImg from "@/assets/images/hero-banner.webp";
---

<section class="relative flex min-h-[65vh] items-center justify-center text-white overflow-hidden">
  <!-- LCP Image: eager + high priority -->
  <Image
    src={heroBannerImg}
    alt="Văn phòng làm việc của công ty Hoàng Nam Cần Thơ"
    width={1920}
    height={600}
    class="absolute inset-0 z-[-2] h-full w-full object-cover"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />
  <!-- Gradient overlay -->
  <div class="absolute inset-0 z-[-1] bg-gradient-to-r from-primary/80 to-primary-light/70"></div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <h1 class="mb-4 text-4xl font-extrabold leading-tight drop-shadow-md md:text-5xl lg:text-6xl">
      Hoàng Nam Cần Thơ
    </h1>
    <p class="mb-10 text-lg text-white/90 md:text-xl">
      Khởi đầu hành trình kinh doanh của bạn một cách chuyên nghiệp, nhanh chóng và đúng pháp luật cùng Hoàng Nam.
    </p>
    <a
      href={`tel:${siteConfig.contact.hotline}`}
      class="group inline-flex items-center justify-center rounded-full bg-white px-8 py-4 text-base font-bold uppercase tracking-wider text-primary shadow-lg transition-all duration-300 hover:scale-105 hover:shadow-xl"
    >
      Yêu Cầu Tư Vấn Ngay
      <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</section>
