---
import { Image } from "astro:assets";
import companyImg from "@/assets/images/services/company.webp";

const services = [
  {
    title: "Tư Vấn Thành Lập Doanh Nghiệp",
    image: companyImg,
    items: [
      "Thành lập doanh nghiệp trong nước",
      "Thành lập doanh nghiệp vốn nước ngoài",
      "Thành lập chi nhánh, văn phòng đại diện",
    ],
  },
  {
    title: "Thay Đổi Giấy Phép Kinh Doanh",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9M4.582 9H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2M19.419 15H15" />`,
    iconColor: "text-amber-600",
    iconBg: "bg-amber-100",
    items: [
      "Thay đổi địa chỉ trụ sở",
      "Chuyển đổi loại hình doanh nghiệp",
      "Thay đổi ngành nghề kinh doanh",
    ],
  },
  {
    title: "Đăng Ký Giấy Phép Kinh Doanh",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
    iconColor: "text-teal-600",
    iconBg: "bg-teal-100",
    items: [
      "Đăng ký doanh nghiệp, hộ kinh doanh",
      "Hỗ trợ giấy phép con theo ngành",
      "Hỗ trợ hồ sơ sau đăng ký",
    ],
  },
  {
    title: "Dịch Vụ Kế Toán",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    iconColor: "text-emerald-600",
    iconBg: "bg-emerald-100",
    items: ["Báo cáo thuế định kỳ", "Sổ sách kế toán", "Báo cáo tài chính"],
  },
  {
    title: "Dịch Vụ Về Thuế",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" />`,
    iconColor: "text-fuchsia-600",
    iconBg: "bg-fuchsia-100",
    items: ["Khai thuế ban đầu", "Khai báo thuế định kỳ", "Quyết toán thuế"],
  },
  {
    title: "Sản Phẩm Số: Hóa Đơn Điện Tử & Chữ Ký Số",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" /><path stroke-linecap="round" stroke-linejoin="round" d="M7 10h10M7 14h6" />`,
    iconColor: "text-violet-600",
    iconBg: "bg-violet-100",
    items: ["Hóa đơn điện tử", "Chữ ký số", "Hỗ trợ triển khai, cài đặt"],
  },
];
---

<section class="bg-gray-50 py-16 md:py-20">
  <div class="mx-auto max-w-7xl px-4">
    <div class="flex items-center justify-center mb-12">
      <div class="flex-grow h-px bg-gray-200"></div>
      <h2
        class="px-8 text-xl md:text-2xl font-bold uppercase tracking-widest text-accent text-center"
      >
        Dịch Vụ Của Chúng Tôi
      </h2>
      <div class="flex-grow h-px bg-gray-200"></div>
    </div>

    <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <a
            href="/dich-vu"
            class="group block rounded-xl bg-white p-8 text-center shadow-lg transition-all duration-300 ease-in-out hover:-translate-y-2 hover:shadow-2xl"
          >
            <div class="mb-6 flex justify-center">
              {service.image ? (
                <Image
                  src={service.image}
                  alt={service.title}
                  width={70}
                  height={70}
                  class="h-16 w-16 object-contain transition-transform duration-300 group-hover:scale-110"
                  loading="lazy"
                />
              ) : (
                <div
                  class:list={[
                    "flex h-16 w-16 items-center justify-center rounded-2xl transition-transform duration-300 group-hover:scale-110",
                    service.iconBg,
                  ]}
                  aria-hidden="true"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class:list={["h-8 w-8", service.iconColor]}
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <Fragment set:html={service.icon} />
                  </svg>
                </div>
              )}
            </div>
            <h3 class="mb-4 flex min-h-[64px] items-center justify-center text-base font-bold uppercase leading-tight text-accent">
              {service.title}
            </h3>
            <ul class="space-y-1">
              {service.items.map((item) => (
                <li class="text-sm leading-relaxed text-gray-600">{item}</li>
              ))}
            </ul>
          </a>
        ))
      }
    </div>
  </div>
</section>
