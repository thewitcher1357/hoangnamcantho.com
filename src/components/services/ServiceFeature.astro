---
interface Props {
  title: string;
  description: string;
  icon?: string;
  colorClass?: string;
}

const { 
  title, 
  description, 
  icon = `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />`,
  colorClass = "text-primary bg-primary/10" 
} = Astro.props;
---
<div class="flex items-start">
  <div class={`flex-shrink-0 mt-1 w-8 h-8 flex items-center justify-center rounded-full ${colorClass} mr-4`}>
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <Fragment set:html={icon} />
    </svg>
  </div>
  <div>
    <h4 class="font-bold text-gray-900 group-hover:text-primary transition-colors">{title}</h4>
    <p class="text-gray-600 text-sm mt-1 leading-relaxed">{description}</p>
  </div>
</div>
