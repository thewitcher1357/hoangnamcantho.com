---
import { siteConfig } from "@/config/site";
---

<footer class="bg-secondary text-white">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-12 py-16 md:grid-cols-2 lg:grid-cols-3">
      <!-- Column 1: Contact Info -->
      <div>
        <h3 class="text-lg font-bold uppercase tracking-wider">Thông tin liên hệ</h3>
        <div class="mt-3 h-0.5 w-12 bg-white"></div>
        <ul class="mt-6 space-y-4 text-sm">
          <li class="flex items-start">
            <span class="mt-1 h-5 w-5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </span>
            <span class="ml-3">{siteConfig.contact.address}</span>
          </li>
          <li class="flex items-start">
            <span class="mt-1 h-5 w-5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </span>
            <a href={`tel:${siteConfig.contact.hotline}`} class="ml-3 transition-opacity hover:opacity-80">
              {siteConfig.contact.hotlineDisplay}
            </a>
          </li>
          <li class="flex items-start">
            <span class="mt-1 h-5 w-5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </span>
            <a href={`mailto:${siteConfig.contact.email}`} class="ml-3 transition-opacity hover:opacity-80">
              {siteConfig.contact.email}
            </a>
          </li>
          <li class="flex items-start">
            <span class="mt-1 h-5 w-5 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
            </span>
            <a href={`https://${siteConfig.contact.website}`} class="ml-3 transition-opacity hover:opacity-80">
              {siteConfig.contact.website}
            </a>
          </li>
        </ul>
      </div>

      <!-- Column 2: About Links -->
      <div>
        <h3 class="text-lg font-bold uppercase tracking-wider">Giới thiệu</h3>
        <div class="mt-3 h-0.5 w-12 bg-white"></div>
        <ul class="mt-6 space-y-3 text-sm">
          {siteConfig.footerLinks.about.map((link) => (
            <li>
              <a href={link.href} class="transition-opacity hover:opacity-80">{link.text}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 3: Newsletter -->
      <div>
        <h3 class="text-lg font-bold uppercase tracking-wider">Đăng ký nhận tin</h3>
        <div class="mt-3 h-0.5 w-12 bg-white"></div>
        <p class="mt-6 text-sm">Đăng ký để nhận thông tin, cập nhật mới nhất từ chúng tôi.</p>
        <form class="mt-4 flex" onsubmit="event.preventDefault();">
          <input
            type="email"
            placeholder="Email của bạn"
            class="w-full rounded-l-md border-0 bg-white px-4 py-2.5 text-gray-900 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-400 focus:outline-none"
          />
          <button
            type="submit"
            class="rounded-r-md bg-blue-500 px-4 font-bold uppercase transition hover:bg-blue-600"
            disabled
            title="Tính năng đang phát triển"
          >
            Nhận tin
          </button>
        </form>
        <div class="mt-6 flex items-center space-x-3">
          <a href={siteConfig.contact.facebook} aria-label="Facebook" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition hover:bg-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
          </a>
          <a href={`mailto:${siteConfig.contact.email}`} aria-label="Email" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/10 transition hover:bg-white/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="bg-secondary-dark">
    <div class="mx-auto flex max-w-7xl items-center justify-center px-6 py-4 text-center text-xs md:justify-between">
      <p>Copyright {new Date().getFullYear()} © Hoàng Nam</p>
    </div>
  </div>
</footer>
