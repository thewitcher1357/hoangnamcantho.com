---
import { siteConfig } from "@/config/site";
---

<div class="fixed bottom-10 left-4 md:left-6 z-50 flex flex-col items-start space-y-3">
  <!-- Zalo Button -->
  <a
    href={siteConfig.contact.zalo}
    target="_blank"
    rel="nofollow"
    aria-label="Chat with us on Zalo"
    class="relative flex h-14 w-14 items-center justify-center rounded-full bg-[#0068FF] shadow-md transition-transform duration-300 hover:scale-110"
  >
    <img
      src="/images/zalo-logo.svg"
      alt="Zalo"
      loading="lazy"
      decoding="async"
      width="32"
      height="32"
      class="h-8 w-8"
    />
    <span class="ripple"></span>
  </a>

  <!-- Phone Button -->
  <a
    href={`tel:${siteConfig.contact.hotline}`}
    rel="nofollow"
    aria-label={`Call us at ${siteConfig.contact.hotlineDisplay}`}
    class="flex items-center rounded-full shadow-lg shadow-red-500/30 phone-ring"
  >
    <div class="relative flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-red-500">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
      </svg>
    </div>
    <div class="hidden sm:flex items-center h-10 rounded-r-full -ml-7 pl-10 pr-4 bg-red-500">
      <span class="text-base font-bold text-white">{siteConfig.contact.hotlineDisplay}</span>
    </div>
  </a>
</div>
