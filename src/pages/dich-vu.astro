---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import CTABanner from "@/components/homepage/CTABanner.astro";

const metadata = {
  title: "Dịch Vụ",
  description:
    "Khám phá các dịch vụ chuyên nghiệp về thành lập, vận hành và giải thể doanh nghiệp tại Cần Thơ.",
};

const services = [
  {
    title: "Thành Lập Công Ty",
    href: "/dich-vu/thanh-lap-cong-ty-tai-can-tho",
    description:
      "Dịch vụ trọn gói giúp bạn khởi đầu doanh nghiệp nhanh chóng, đúng pháp luật tại Cần Thơ.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />`,
    features: [
      "Tư vấn loại hình doanh nghiệp",
      "Soạn hồ sơ & nộp đăng ký",
      "Nhận giấy phép trong 3-5 ngày",
      "Khắc dấu & mã số thuế",
    ],
    color: "from-blue-500 to-blue-600",
    bgLight: "bg-blue-50",
    ringColor: "ring-blue-200",
  },
  {
    title: "Làm Giấy Phép Kinh Doanh",
    href: "/dich-vu/lam-giay-phep-kinh-doanh-tai-can-tho",
    description:
      "Hỗ trợ đăng ký cho hộ kinh doanh cá thể và các giấy phép con cho doanh nghiệp tại Cần Thơ.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />`,
    features: [
      "Giấy phép kinh doanh hộ cá thể",
      "Giấy phép con (VSATTP, PCCC...)",
      "Giấy phép đầu tư",
      "Chứng chỉ hành nghề",
    ],
    color: "from-teal-500 to-teal-600",
    bgLight: "bg-teal-100",
    ringColor: "ring-teal-200",
  },
  {
    title: "Giải Thể Công Ty",
    href: "/dich-vu/giai-the-cong-ty-o-can-tho",
    description:
      "Quy trình chuyên nghiệp giúp bạn kết thúc hoạt động kinh doanh một cách nhẹ nhàng, đúng pháp luật.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />`,
    features: [
      "Tư vấn thủ tục giải thể",
      "Quyết toán thuế & bảo hiểm",
      "Đăng bố giải thể",
      "Trả con dấu & giấy phép",
    ],
    color: "from-red-500 to-red-600",
    bgLight: "bg-red-50",
    ringColor: "ring-red-200",
  },
  {
    title: "Dịch Vụ Kế Toán Thuế",
    href: "/dich-vu/dich-vu-ke-toan-can-tho",
    description:
      "Dịch vụ kế toán trọn gói: báo cáo thuế, sổ sách kế toán, hóa đơn điện tử cho doanh nghiệp tại Cần Thơ.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />`,
    features: [
      "Kê khai thuế GTGT, TNCN, TNDN",
      "Quản lý sổ sách kế toán",
      "Báo cáo tài chính cuối năm",
      "Giải trình thuế & tư vấn pháp lý",
    ],
    color: "from-emerald-500 to-emerald-600",
    bgLight: "bg-emerald-50",
    ringColor: "ring-emerald-200",
  },
  {
    title: "Hóa Đơn Điện Tử",
    href: "/dich-vu/hoa-don-dien-tu-can-tho",
    description:
      "Cung cấp giải pháp hóa đơn điện tử uy tín từ Hona-Invoice, Viettel, BKAV với giá cạnh tranh nhất.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />`,
    features: [
      "Đáp ứng TT 78/2021/TT-BTC",
      "Hona-Invoice giá rẻ nhất",
      "Triển khai nhanh trong ngày",
      "Hỗ trợ kỹ thuật 24/7",
    ],
    color: "from-violet-500 to-violet-600",
    bgLight: "bg-violet-50",
    ringColor: "ring-violet-200",
  },
  {
    title: "Chữ Ký Số",
    href: "/dich-vu/chu-ky-so-can-tho",
    description:
      "Đại lý phân phối chữ ký số hàng đầu: Viettel-CA, FPT-CA, VNPT-CA, BKAV-CA với giá ưu đãi tốt nhất.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />`,
    features: [
      "Mua 3 năm tặng 1 năm",
      "Hỗ trợ kê khai thuế, hải quan",
      "CKS mềm ký HĐĐT không cần Token",
      "Cài đặt tận nơi miễn phí",
    ],
    color: "from-amber-500 to-amber-600",
    bgLight: "bg-amber-50",
    ringColor: "ring-amber-200",
  },
  {
    title: "Thành Lập CT Vốn Nước Ngoài",
    href: "/dich-vu/thanh-lap-cong-ty-von-dau-tu-nuoc-ngoai-tai-can-tho",
    description:
      "Dịch vụ xin giấy chứng nhận đầu tư, thành lập doanh nghiệp FDI tại Cần Thơ, uy tín, nhanh chóng.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    features: [
      "Xin cấp GCN đăng ký đầu tư",
      "Thành lập DNNN tại Cần Thơ",
      "Tư vấn tỷ lệ góp vốn",
      "Hậu mãi 12 tháng miễn phí",
    ],
    color: "from-cyan-500 to-cyan-600",
    bgLight: "bg-cyan-50",
    ringColor: "ring-cyan-200",
  },
];

const additionalServices = [
  {
    title: "Thiết Kế Website",
    description: "Thiết kế website chuyên nghiệp, tối ưu SEO cho doanh nghiệp.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />`,
  },
  {
    title: "SEO Google",
    description: "Tối ưu thứ hạng tìm kiếm, đưa website của bạn lên top Google.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />`,
  },
  {
    title: "Phần Mềm Kế Toán",
    description: "Cung cấp và triển khai phần mềm kế toán phù hợp cho doanh nghiệp.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  },
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-24">
    <div class="relative z-10">
      <h1 class="text-4xl font-bold drop-shadow-md md:text-5xl">Dịch Vụ Của Chúng Tôi</h1>
      <p class="mt-4 text-lg text-white/90">
        Giải pháp toàn diện cho doanh nghiệp của bạn tại Cần Thơ
      </p>
    </div>
  </section>

  <!-- Main Services -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-accent sm:text-4xl">
          Dịch Vụ Chính
        </h2>
        <p class="mt-4 mx-auto max-w-2xl text-lg text-gray-600">
          Chúng tôi cung cấp các dịch vụ trọn gói, chuyên nghiệp giúp bạn yên tâm
          phát triển kinh doanh.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <a
            href={service.href}
            class:list={[
              "group relative flex flex-col overflow-hidden rounded-2xl p-8 ring-1 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl",
              service.bgLight,
              service.ringColor,
            ]}
          >
            <!-- Icon -->
            <div class:list={[
              "flex h-14 w-14 items-center justify-center rounded-xl bg-gradient-to-br text-white shadow-lg transition-transform duration-300 group-hover:scale-110",
              service.color,
            ]}>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <Fragment set:html={service.icon} />
              </svg>
            </div>

            <!-- Content -->
            <h3 class="mt-6 text-xl font-bold text-accent">{service.title}</h3>
            <p class="mt-3 text-gray-600">{service.description}</p>

            <!-- Features list -->
            <ul class="mt-5 space-y-2 flex-1">
              {service.features.map((feature) => (
                <li class="flex items-start text-sm text-gray-700">
                  <svg xmlns="http://www.w3.org/2000/svg" class="mr-2 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <span class="mt-6 inline-flex items-center text-base font-semibold text-primary transition-colors group-hover:text-primary-dark">
              Xem chi tiết
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Bạn cần tư vấn dịch vụ phù hợp?"
    subtitle="Liên hệ ngay với Hoàng Nam để được tư vấn miễn phí và chọn gói dịch vụ tốt nhất cho doanh nghiệp của bạn."
  />

  <!-- Additional Services -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-accent sm:text-4xl">
          Dịch Vụ Bổ Sung
        </h2>
        <p class="mt-4 mx-auto max-w-2xl text-lg text-gray-600">
          Ngoài các dịch vụ chính, chúng tôi còn cung cấp nhiều giải pháp hỗ trợ
          doanh nghiệp toàn diện.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {additionalServices.map((service) => (
          <div class="group flex items-start gap-x-5 rounded-xl bg-white p-6 ring-1 ring-gray-200 transition-all duration-300 hover:shadow-lg hover:ring-primary/20">
            <div class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors duration-300 group-hover:bg-primary group-hover:text-white">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <Fragment set:html={service.icon} />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-gray-900">{service.title}</h3>
              <p class="mt-1 text-sm text-gray-600">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-accent sm:text-4xl">
          Tại Sao Chọn Hoàng Nam?
        </h2>
      </div>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary text-white">
            <span class="text-2xl font-black">10+</span>
          </div>
          <h3 class="mt-4 text-lg font-bold text-gray-900">Năm Kinh Nghiệm</h3>
          <p class="mt-2 text-sm text-gray-600">Hơn 10 năm hoạt động, phục vụ hàng nghìn doanh nghiệp.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-gray-900">Giá Cả Cạnh Tranh</h3>
          <p class="mt-2 text-sm text-gray-600">Chi phí rõ ràng, không phát sinh, cạnh tranh nhất khu vực.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-gray-900">Nhanh Chóng</h3>
          <p class="mt-2 text-sm text-gray-600">Xử lý hồ sơ nhanh, giấy phép có trong 3-5 ngày làm việc.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-primary text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-gray-900">Uy Tín & Bảo Mật</h3>
          <p class="mt-2 text-sm text-gray-600">Cam kết bảo mật thông tin, đồng hành suốt quá trình.</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
