---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";

const metadata = {
  title: "Liên Hệ",
  description:
    "Liên hệ với Hoàng Nam Cần Thơ để được tư vấn chuyên nghiệp về thành lập doanh nghiệp, kế toán và các dịch vụ pháp lý khác tại Cần Thơ.",
};

const contactCards = [
  {
    title: "Địa chỉ",
    value: siteConfig.contact.address,
    icon: `<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle>`,
    href: `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(siteConfig.contact.address)}`,
    linkText: "Xem bản đồ",
    color: "bg-red-50",
    iconBg: "bg-red-500",
    ring: "ring-red-200",
  },
  {
    title: "Điện thoại",
    value: siteConfig.contact.hotlineDisplay,
    icon: `<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>`,
    href: `tel:${siteConfig.contact.hotline}`,
    linkText: "Gọi ngay",
    color: "bg-teal-100",
    iconBg: "bg-teal-500",
    ring: "ring-teal-200",
  },
  {
    title: "Email",
    value: siteConfig.contact.email,
    icon: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline>`,
    href: `mailto:${siteConfig.contact.email}`,
    linkText: "Gửi email",
    color: "bg-blue-50",
    iconBg: "bg-blue-500",
    ring: "ring-blue-200",
  },
  {
    title: "Zalo",
    value: "Chat trực tiếp qua Zalo",
    icon: `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>`,
    href: siteConfig.contact.zalo,
    linkText: "Chat Zalo",
    color: "bg-blue-100",
    iconBg: "bg-[#0068FF]",
    ring: "ring-blue-200",
  },
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-24">
    <div class="relative z-10">
      <h1 class="text-4xl font-bold drop-shadow-md md:text-5xl">Liên Hệ</h1>
      <p class="mt-4 text-lg text-white/90">
        Hoàng Nam Cần Thơ - Sẵn Sàng Hỗ Trợ Bạn
      </p>
    </div>
  </section>

  <!-- Contact Cards -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold tracking-tight text-accent md:text-4xl">
          Thông Tin Liên Hệ
        </h2>
        <p class="mt-4 mx-auto max-w-2xl text-lg text-gray-600">
          Hãy liên hệ với chúng tôi qua bất kỳ kênh nào phù hợp nhất với bạn.
          Chúng tôi phản hồi trong vòng 2 giờ.
        </p>
      </div>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {contactCards.map((card) => (
          <a
            href={card.href}
            target={card.href.startsWith("http") ? "_blank" : undefined}
            rel={card.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class:list={[
              "group flex flex-col items-center rounded-2xl p-8 text-center ring-1 transition-all duration-300 hover:-translate-y-2 hover:shadow-xl",
              card.color,
              card.ring,
            ]}
          >
            <div class:list={[
              "flex h-16 w-16 items-center justify-center rounded-full text-white shadow-lg transition-transform duration-300 group-hover:scale-110",
              card.iconBg,
            ]}>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={card.icon} />
              </svg>
            </div>
            <h3 class="mt-6 text-lg font-bold text-gray-900">{card.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{card.value}</p>
            <span class="mt-4 inline-flex items-center text-sm font-semibold text-primary transition-colors group-hover:text-primary-dark">
              {card.linkText}
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-1 h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact Form + Map -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-2">
        <!-- Form -->
        <div>
          <h2 class="text-3xl font-bold tracking-tight text-accent md:text-4xl">
            Gửi Yêu Cầu Tư Vấn
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            Để lại thông tin bên dưới, chúng tôi sẽ liên hệ lại trong thời gian
            sớm nhất.
          </p>
          <form action="#" method="POST" class="mt-8 space-y-5">
            <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <input
                type="text"
                name="name"
                placeholder="Họ và tên *"
                required
                class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-800 placeholder:text-sm placeholder:text-gray-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              />
              <input
                type="tel"
                name="phone"
                placeholder="Số điện thoại *"
                required
                class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-800 placeholder:text-sm placeholder:text-gray-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
              />
            </div>
            <input
              type="email"
              name="email"
              placeholder="Email (không bắt buộc)"
              class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-800 placeholder:text-sm placeholder:text-gray-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
            />
            <select
              name="service"
              class="w-full rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-800 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
            >
              <option value="" disabled selected>Chọn dịch vụ quan tâm</option>
              <option value="thanh-lap-cong-ty">Thành lập công ty</option>
              <option value="ke-toan-thue">Dịch vụ kế toán thuế</option>
              <option value="giay-phep">Giấy phép kinh doanh</option>
              <option value="giai-the">Giải thể công ty</option>
              <option value="khac">Dịch vụ khác</option>
            </select>
            <textarea
              name="message"
              rows="5"
              placeholder="Nội dung yêu cầu tư vấn..."
              class="w-full min-h-[120px] rounded-lg border border-gray-200 bg-white px-4 py-3 text-gray-800 placeholder:text-sm placeholder:text-gray-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500 focus:outline-none"
            ></textarea>
            <button
              type="submit"
              class="inline-flex w-full items-center justify-center rounded-lg bg-primary px-8 py-4 text-base font-bold uppercase tracking-wider text-white shadow-lg transition-all duration-300 hover:bg-primary-dark hover:shadow-xl sm:w-auto"
            >
              Gửi Yêu Cầu Tư Vấn
              <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
            </button>
          </form>
        </div>

        <!-- Map -->
        <div class="flex flex-col">
          <h2 class="text-3xl font-bold tracking-tight text-accent md:text-4xl">
            Bản Đồ
          </h2>
          <p class="mt-4 text-lg text-gray-600">
            {siteConfig.contact.address}
          </p>
          <div class="mt-8 flex-1 overflow-hidden rounded-2xl shadow-lg ring-1 ring-gray-200">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3928.875!2d105.7685!3d10.0303!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x31a0881!2sXu%C3%A2n+Kh%C3%A1nh%2C+Ninh+Ki%E1%BB%81u%2C+C%E1%BA%A7n+Th%C6%A1!5e0!3m2!1svi!2svn!4v1700000000000"
              width="100%"
              height="100%"
              style="border:0; min-height: 400px;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Bản đồ Hoàng Nam Cần Thơ"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Working Hours -->
  <section class="bg-gradient-to-r from-primary to-primary-light py-16">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 text-center md:grid-cols-3">
        <div>
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-white/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
          </div>
          <h3 class="mt-6 text-xl font-bold text-white">Giờ làm việc</h3>
          <p class="mt-2 text-white/80">Thứ 2 - Thứ 7</p>
          <p class="text-lg font-bold text-white">08:00 - 17:30</p>
        </div>
        <div>
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-white/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
          </div>
          <h3 class="mt-6 text-xl font-bold text-white">Hỗ trợ 24/7</h3>
          <p class="mt-2 text-white/80">Hotline tư vấn</p>
          <a href={`tel:${siteConfig.contact.hotline}`} class="text-lg font-bold text-white hover:underline">
            {siteConfig.contact.hotlineDisplay}
          </a>
        </div>
        <div>
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-white/10">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
          </div>
          <h3 class="mt-6 text-xl font-bold text-white">Email</h3>
          <p class="mt-2 text-white/80">Gửi yêu cầu qua email</p>
          <a href={`mailto:${siteConfig.contact.email}`} class="text-lg font-bold text-white hover:underline">
            {siteConfig.contact.email}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
