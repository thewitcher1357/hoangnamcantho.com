---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { siteConfig } from "@/config/site";
import CTABanner from "@/components/homepage/CTABanner.astro";
import heroImage from "@/assets/images/services/thanh-lap-cong-ty-fdi.png";

const metadata = {
  title: "Thành Lập Công Ty Vốn Đầu Tư Nước Ngoài Tại Cần Thơ – Hoàng Nam",
  description:
    "Dịch vụ thành lập doanh nghiệp có vốn đầu tư nước ngoài (FDI) tại Cần Thơ. Hoàng Nam tư vấn xin giấy chứng nhận đầu tư, thành lập công ty nhanh chóng, uy tín.",
};

const benefits = [
  { icon: "🤝", title: "LINH HOẠT", description: "Kỹ năng làm việc đa kênh qua email/zalo/điện thoại, phù hợp với mọi khách hàng." },
  { icon: "⚖️", title: "CHÍNH XÁC", description: "Làm đúng nội dung, đúng trình tự và đúng pháp luật." },
  { icon: "💰", title: "PHÍ TỐT NHẤT", description: "Khách hàng yên tâm với phí dịch vụ tốt nhất." },
  { icon: "⚡", title: "NHANH CHÓNG", description: "Công việc tiến hành nhanh chóng và đúng hẹn." },
  { icon: "🛵", title: "TẬN NƠI", description: "Chúng tôi không ngại di chuyển để hỗ trợ." },
  { icon: "💙", title: "CHU ĐÁO", description: "Tư vấn và nhắc nhở tận tình sau thành lập." },
  { icon: "🎁", title: "HẬU MÃI", description: "Tư vấn miễn phí 12 tháng sau thành lập." },
  { icon: "🏆", title: "THÀNH CÔNG", description: "HOÀNG NAM luôn theo đuổi mục tiêu cho đến thành công." },
];

const step2Docs = [
  "Bản sao Giấy chứng nhận đăng ký đầu tư",
  "Giấy đề nghị Đăng ký doanh nghiệp",
  "Danh sách thành viên đối với công ty TNHH hai thành viên, cổ đông sáng lập đối với doanh nghiệp cổ phần",
  "Dự thảo điều lệ doanh nghiệp",
];

const step2DocsPersonal = [
  "Đối với cá nhân: Chứng minh thư nhân dân hoặc hộ chiếu còn hiệu lực",
  "Đối với tổ chức: Giấy Chứng nhận đăng ký doanh nghiệp kèm theo giấy tờ chứng thực cá nhân, quyết định uỷ quyền",
  "Quyết định góp vốn đối với thành viên công ty, cổ đông công ty là tổ chức",
  "Hợp đồng ủy quyền cho HOÀNG NAM thực hiện thủ tục",
];

const companyBenefits = [
  "Mọi thủ tục, hồ sơ sẽ được Hoàng Nam soạn thảo, chuẩn bị và đảm bảo phù hợp quy định pháp luật.",
  "Doanh nghiệp sẽ được các chuyên gia pháp luật, luật sư dày dạn kinh nghiệm tư vấn nhiệt tình, cặn kẽ.",
  "Hoàng Nam cam kết thời gian thành lập doanh nghiệp tại Cần Thơ nhanh chóng, thuận lợi.",
  "Hồ sơ, thông tin nhà đầu tư được Hoàng Nam bảo mật tuyệt đối.",
  "Hoàng Nam sẽ thay mặt nhà đầu tư xử lý những hồ sơ bị vướng mắc, gặp trở ngại.",
  "Giá cả dịch vụ luôn cạnh tranh trên thị trường, đảm bảo uy tín, chất lượng.",
];

const publishContent = [
  "Tên công ty",
  "Trụ sở chính công ty",
  "Thông tin người đại diện theo pháp luật của doanh nghiệp",
  "Danh sách thành viên (TNHH), cổ đông sáng lập và cổ đông là nhà đầu tư nước ngoài (cổ phần)",
  "Vốn điều lệ",
  "Ngành, nghề kinh doanh",
];

const hoangNamServices = [
  "Tư vấn lựa chọn loại hình doanh nghiệp phù hợp: Công ty TNHH hay Công ty cổ phần, địa chỉ trụ sở, vốn, ngành nghề kinh doanh.",
  "Tư vấn tỷ lệ góp vốn của nhà đầu tư nước ngoài tại Việt Nam.",
  "Tư vấn điều kiện, hướng dẫn nhà đầu tư chuẩn bị tài liệu cần thiết để thành lập công ty có vốn đầu tư nước ngoài tại Cần Thơ.",
  "Tư vấn, soạn thảo hồ sơ thành lập doanh nghiệp cho nhà đầu tư.",
  "Đại diện nhà đầu tư làm việc với các cơ quan nhà nước có thẩm quyền trong quá trình thành lập doanh nghiệp.",
  "Tư vấn toàn diện các hoạt động phát sinh trong quá trình thực hiện kinh doanh tại Việt Nam.",
];

const supportAreas = [
  "Ninh Kiều", "Cái Răng", "Bình Thủy", "Ô Môn", "Thốt Nốt",
  "Phong Điền", "Cờ Đỏ", "Vĩnh Thạnh", "Thới Lai",
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Thành Lập Công Ty Vốn Đầu Tư Nước Ngoài Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Uy Tín – Chuyên Nghiệp – Nhanh Chóng – Đồng Hành Toàn Diện
      </p>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Bạn muốn tìm <strong class="text-primary">dịch vụ thành lập công ty có vốn đầu tư nước ngoài tại Cần Thơ</strong>{" "}
          nhưng lại không biết phải chuẩn bị hồ sơ, thủ tục ra sao mới có thể bắt đầu?
        </p>
        <p class="text-justify">
          <strong class="text-primary">Dịch vụ thành lập doanh nghiệp có vốn đầu tư nước ngoài tại Cần Thơ của Hoàng Nam</strong>{" "}
          sẽ giúp các nhà đầu tư nước ngoài muốn đầu tư vào khu vực Cần Thơ bỏ qua những lo lắng và khó khăn ban đầu
          khi thực hiện thủ tục mở doanh nghiệp.
        </p>
      </div>

      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Thành lập công ty có vốn đầu tư nước ngoài"
          width={815}
          height={545}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>

      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Dịch Vụ Thành Lập doanh nghiệp của <strong class="text-primary">Hoàng Nam</strong> sẽ tư vấn và thực hiện
          tốt nhất để giúp bạn xin cấp được <strong>giấy chứng nhận đầu tư</strong> với thời gian nhanh chóng
          và chi phí hợp lý nhất.
        </p>
      </div>
    </div>
  </section>

  <!-- Lợi ích -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Lợi Ích Khi Sử Dụng Dịch Vụ Của Hoàng Nam
      </h2>
      <p class="mt-6 text-lg text-gray-700">
        <strong class="text-primary">HOÀNG NAM</strong> luôn cố gắng mang đến dịch vụ tốt nhất cho khách hàng:
      </p>
      <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {benefits.map((benefit) => (
          <div class="group rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
            <div class="mb-3 text-3xl">{benefit.icon}</div>
            <strong class="block text-lg text-primary">{benefit.title}</strong>
            <p class="mt-2 text-sm text-gray-600">{benefit.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 rounded-r-xl border-l-[6px] border-primary bg-blue-50 px-8 py-6">
        <p class="text-lg font-bold text-primary text-center">
          📞 Đừng ngần ngại hãy gọi ngay cho HOÀNG NAM để được tư vấn, hướng dẫn nhanh chóng và hiệu quả!
        </p>
      </div>
    </div>
  </section>

  <!-- Quy trình -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Quy Trình Thành Lập Doanh Nghiệp Vốn Đầu Tư Nước Ngoài
      </h2>

      <!-- Bước 1 -->
      <div class="mt-10 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
        <div class="flex items-center gap-4 mb-6">
          <span class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xl font-bold text-white">1</span>
          <h3 class="text-xl font-bold text-primary">Xin Cấp Giấy Chứng Nhận Đầu Tư</h3>
        </div>
        <div class="ml-18 space-y-4">
          <div class="flex items-start gap-3 rounded-lg bg-gray-50 p-4">
            <span class="text-primary font-bold">•</span>
            <p class="text-gray-700">Nhà đầu tư tiến hành kê khai trực tuyến các thông tin về dự án qua cổng thông tin quốc gia về đầu tư nước ngoài. Sau khi kê khai, nộp hồ sơ cấp Giấy chứng nhận đăng ký đầu tư cho Cơ quan đăng ký đầu tư.</p>
          </div>
          <div class="flex items-start gap-3 rounded-lg bg-gray-50 p-4">
            <span class="text-primary font-bold">•</span>
            <p class="text-gray-700">Sau khi Cơ quan đăng ký đầu tư tiếp nhận hồ sơ, nhà đầu tư được cấp tài khoản truy cập Hệ thống thông tin quốc gia về đầu tư nước ngoài để theo dõi tình hình xử lý hồ sơ.</p>
          </div>
          <div class="flex items-start gap-3 rounded-lg bg-gray-50 p-4">
            <span class="text-primary font-bold">•</span>
            <p class="text-gray-700">Cơ quan đăng ký đầu tư sử dụng Hệ thống để tiếp nhận, xử lý, trả kết quả hồ sơ đăng ký đầu tư, cập nhật tình hình xử lý và cấp mã số cho dự án đầu tư.</p>
          </div>
        </div>
      </div>

      <!-- Bước 2 -->
      <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
        <div class="flex items-center gap-4 mb-6">
          <span class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xl font-bold text-white">2</span>
          <h3 class="text-xl font-bold text-primary">Thủ Tục Cấp GCNĐK Doanh Nghiệp</h3>
        </div>
        <p class="text-gray-700 mb-4">
          Sau khi được cấp Giấy chứng nhận đăng ký đầu tư, doanh nghiệp nộp hồ sơ tới Phòng ĐKKD Sở KH&ĐT Cần Thơ.
        </p>
        <div class="mb-4">
          <h4 class="font-bold text-gray-800 mb-3">Hồ sơ bao gồm:</h4>
          <div class="space-y-2">
            {step2Docs.map((doc) => (
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span class="text-gray-700">{doc}</span>
              </div>
            ))}
          </div>
        </div>
        <div>
          <h4 class="font-bold text-gray-800 mb-3">Bản sao hợp lệ giấy tờ chứng thực:</h4>
          <div class="space-y-2">
            {step2DocsPersonal.map((doc) => (
              <div class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 flex-shrink-0 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
                <span class="text-gray-700">{doc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Bước 3 -->
      <div class="mt-6 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
        <div class="flex items-center gap-4 mb-6">
          <span class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary text-xl font-bold text-white">3</span>
          <h3 class="text-xl font-bold text-primary">Công Bố Nội Dung Đăng Ký Doanh Nghiệp</h3>
        </div>
        <p class="text-gray-700 mb-4">
          Nhà đầu tư có thể tiến hành khắc con dấu pháp nhân, thông báo sử dụng mẫu dấu của công ty.
        </p>
        <div class="mb-4">
          <h4 class="font-bold text-gray-800 mb-3">Nội dung công bố bao gồm:</h4>
          <div class="grid grid-cols-1 gap-2 md:grid-cols-2">
            {publishContent.map((item) => (
              <div class="flex items-start gap-2">
                <span class="text-primary">•</span>
                <span class="text-gray-700">{item}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="rounded-r-xl border-l-[6px] border-amber-500 bg-amber-50 px-6 py-4">
          <p class="text-sm text-amber-800">
            <strong>⏰ Thời hạn:</strong> Trong vòng 30 ngày kể từ ngày được cấp GCNĐKDN, doanh nghiệp phải
            thực hiện công bố trên Cổng thông tin quốc gia về đăng ký doanh nghiệp.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Lợi ích khi dùng HN -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Lợi Ích Khi Sử Dụng Dịch Vụ Hoàng Nam
      </h2>
      <p class="mt-6 text-gray-700">
        Nếu bạn có nhu cầu thành lập công ty vốn FDI tại Cần Thơ thì tốt nhất nên sử dụng dịch vụ của Hoàng Nam:
      </p>
      <div class="mt-8 space-y-4">
        {companyBenefits.map((benefit) => (
          <div class="flex items-start gap-3 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-all hover:shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-6 w-6 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">{benefit}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Dịch vụ của Hoàng Nam -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Dịch Vụ Của Công Ty Hoàng Nam
      </h2>
      <div class="mt-8 flex flex-col gap-4">
        {hoangNamServices.map((service, index) => (
          <div class="flex items-start gap-5 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-all duration-300 hover:shadow-md">
            <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {index + 1}
            </span>
            <p class="text-gray-700 pt-2">{service}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Khu Vực Hỗ Trợ -->
  <section class="bg-gray-50 py-12">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border-2 border-dashed border-primary bg-blue-50 p-8 text-center">
        <p class="text-lg font-bold text-primary">
          📍 Hỗ trợ tận nơi tại Cần Thơ:{" "}
          <span class="font-normal text-gray-700">
            {supportAreas.join(", ")}.
          </span>
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    title="Bạn muốn thành lập công ty vốn đầu tư nước ngoài tại Cần Thơ?"
    subtitle="Liên hệ ngay Hoàng Nam để được tư vấn miễn phí, xin giấy phép đầu tư nhanh chóng và chi phí hợp lý nhất."
  />
</BaseLayout>
