---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { siteConfig } from "@/config/site";
import CTABanner from "@/components/homepage/CTABanner.astro";
import heroImage from "@/assets/images/services/dich-vu-ke-toan.png";

const metadata = {
  title: "Dịch Vụ Kế Toán Thuế Tại Cần Thơ – Trọn Gói, Uy Tín, Giá Tốt",
  description:
    "Hoàng Nam cung cấp dịch vụ kế toán thuế trọn gói tại Cần Thơ. Kê khai thuế, báo cáo tài chính, sổ sách kế toán đúng quy định. Tiết kiệm 60% chi phí.",
};

const risks = [
  {
    icon: "⚠️",
    title: "Phạt hành chính",
    description: "Theo Nghị định 125/2020/NĐ-CP, doanh nghiệp có thể bị phạt từ 500.000 đến 8 triệu đồng nếu kê khai thuế sai hoặc chậm trễ.",
  },
  {
    icon: "📋",
    title: "Sai sót sổ sách",
    description: "Gây khó khăn trong kiểm tra thuế, ảnh hưởng uy tín với đối tác.",
  },
  {
    icon: "⏰",
    title: "Mất thời gian",
    description: "Tự làm kế toán khiến bạn mất cơ hội tập trung phát triển kinh doanh.",
  },
];

const hireBenefits = [
  {
    icon: "💰",
    title: "Tiết kiệm chi phí",
    description: "Giảm đến 60% chi phí so với thuê nhân sự kế toán chuyên trách.",
  },
  {
    icon: "⚖️",
    title: "Đảm bảo tuân thủ pháp luật",
    description: "Báo cáo thuế, hóa đơn điện tử và sổ sách đúng quy định.",
  },
  {
    icon: "🎯",
    title: "Tư vấn chuyên sâu",
    description: "Hỗ trợ tối ưu hóa thuế và giải trình với cơ quan thuế.",
  },
];

const targetAudience = [
  {
    title: "Doanh nghiệp vừa và nhỏ",
    description: "Các công ty mới thành lập hoặc có quy mô nhỏ cần hỗ trợ quản lý tài chính.",
  },
  {
    title: "Hộ kinh doanh cá thể",
    description: "Cần dọn dẹp sổ sách, kê khai thuế và sử dụng hóa đơn điện tử.",
  },
  {
    title: "Doanh nghiệp gặp khó khăn về thuế",
    description: "Lo ngại sai sót trong báo cáo thuế hoặc cần giải trình với cơ quan thuế.",
  },
  {
    title: "Doanh nghiệp cần tư vấn pháp lý",
    description: "Tìm hiểu về chế độ kế toán, thuế GTGT, thuế TNDN, thuế TNCN.",
  },
];

const mainServices = [
  "Kê khai thuế: Báo cáo thuế GTGT, TNCN, TNDN hàng tháng, quý, năm đúng hạn.",
  "Quản lý sổ sách kế toán: Ghi chép, lưu trữ hóa đơn, chứng từ khoa học.",
  "Hóa đơn điện tử: Hỗ trợ đăng ký, phát hành và quản lý hóa đơn theo Nghị định 123/2020/NĐ-CP.",
  "Báo cáo tài chính: Chuẩn bị báo cáo tài chính cuối năm phục vụ kiểm tra thuế.",
  "Tư vấn thuế và pháp lý: Tối ưu hóa chi phí thuế, cập nhật các quy định mới.",
  "Giải trình thuế: Đại diện làm việc với cơ quan thuế khi có kiểm tra hoặc thanh tra.",
  "Dịch vụ kế toán bán thời gian: Đến công ty để setup hệ thống kế toán theo yêu cầu.",
];

const freeConsulting = [
  "Chế độ kế toán: Lựa chọn phương pháp kê khai phù hợp (khoán hoặc kê khai).",
  "Lệ phí môn bài: Hướng dẫn nộp lệ phí môn bài hàng năm sau khi thành lập công ty.",
  "Thuế GTGT và TNDN: Tối ưu hóa chi phí thuế trong khuôn khổ pháp luật.",
  "Các quy định pháp lý: Cập nhật thông tư, nghị định mới nhất để đảm bảo tuân thủ.",
];

const processSteps = [
  {
    title: "Tiếp Nhận và Phân Tích Nhu Cầu",
    details: [
      "Tư vấn miễn phí để hiểu quy mô kinh doanh và tình trạng tài chính hiện tại.",
      "Đánh giá số lượng chứng từ, phương pháp kê khai thuế và yêu cầu cụ thể.",
    ],
  },
  {
    title: "Thực Hiện Báo Cáo Thuế và Sổ Sách Kế Toán",
    details: [
      "Thu thập hóa đơn, chứng từ từ doanh nghiệp.",
      "Kê khai và nộp báo cáo thuế GTGT, TNCN, TNDN đúng hạn.",
      "Hạch toán, sắp xếp sổ sách kế toán khoa học, sẵn sàng cho kiểm tra thuế.",
    ],
  },
  {
    title: "Tư Vấn và Hỗ Trợ Liên Tục",
    details: [
      "Cập nhật các quy định mới về thuế và kế toán.",
      "Hỗ trợ giải trình với cơ quan thuế khi cần.",
      "Tư vấn chiến lược tài chính để tối ưu hóa lợi nhuận.",
    ],
  },
];

const pricingTable = [
  { docs: "Không phát sinh", tm: "500,000", xd: "500,000", sx: "500,000" },
  { docs: "Dưới 5 chứng từ", tm: "800,000", xd: "800,000", sx: "800,000" },
  { docs: "5-10 chứng từ", tm: "1,000,000", xd: "1,200,000", sx: "1,200,000" },
  { docs: "11-20 chứng từ", tm: "1,200,000", xd: "1,400,000", sx: "1,400,000" },
  { docs: "21-30 chứng từ", tm: "1,400,000", xd: "1,600,000", sx: "1,600,000" },
  { docs: "31-40 chứng từ", tm: "1,600,000", xd: "1,800,000", sx: "1,800,000" },
  { docs: "Trên 40 chứng từ", tm: "Thỏa thuận", xd: "Thỏa thuận", sx: "Thỏa thuận" },
];

const discounts = [
  { method: "Thanh toán theo tháng", detail: "Thanh toán trong 5 ngày kể từ khi tờ khai được cơ quan thuế chấp thuận." },
  { method: "Thanh toán 3 tháng/lần", detail: "Giảm 10%." },
  { method: "Thanh toán 4 tháng/lần", detail: "Giảm 15%." },
  { method: "Thanh toán 5 tháng/lần", detail: "Giảm 20%." },
  { method: "Thanh toán 6 tháng/lần", detail: "Miễn phí nộp báo cáo tài chính cuối năm." },
];

const supportAreas = [
  "Ninh Kiều", "Cái Răng", "Bình Thủy", "Ô Môn", "Thốt Nốt",
  "Phong Điền", "Cờ Đỏ", "Vĩnh Thạnh", "Thới Lai",
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Kế Toán Thuế Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Trọn Gói – Chuyên Nghiệp – Đúng Luật – Tiết Kiệm 60% Chi Phí
      </p>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Bạn đang tìm <strong class="text-primary">dịch vụ kế toán thuế tại Cần Thơ</strong> uy tín, chuyên nghiệp
          để quản lý sổ sách, báo cáo thuế và tuân thủ pháp luật? <strong>Hoàng Nam</strong> cung cấp giải pháp
          kế toán trọn gói cho doanh nghiệp vừa và nhỏ, hộ kinh doanh tại Cần Thơ, Hậu Giang, Đồng Tháp,
          Vĩnh Long và các tỉnh lân cận.
        </p>
        <p class="text-justify">
          Với đội ngũ chuyên gia giàu kinh nghiệm, chúng tôi đảm bảo xử lý <strong>báo cáo thuế</strong>,
          <strong>hóa đơn điện tử</strong> và <strong>sổ sách kế toán</strong> đúng quy định
          <strong>Luật Doanh nghiệp 2020</strong>, <strong>Nghị định 123/2020/NĐ-CP</strong> và
          <strong>Thông tư 40/2021/TT-BTC</strong>, giúp bạn tiết kiệm thời gian và chi phí.
        </p>
      </div>

      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Dịch vụ kế toán thuế tại Cần Thơ"
          width={815}
          height={545}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Tại sao cần DV -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Tại Sao Doanh Nghiệp Cần Dịch Vụ Kế Toán Thuế Chuyên Nghiệp?
      </h2>
      <p class="mt-6 text-lg text-gray-700">
        Hàng nghìn doanh nghiệp tại Cần Thơ đã tin tưởng Hoàng Nam để xử lý các vấn đề kế toán và thuế.
      </p>

      <div class="mt-10">
        <h3 class="text-xl font-bold text-red-600 mb-6">⚠️ Những Rủi Ro Khi Tự Làm Kế Toán</h3>
        <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
          {risks.map((risk) => (
            <div class="rounded-2xl border border-red-100 bg-red-50 p-6 shadow-sm">
              <div class="text-3xl mb-3">{risk.icon}</div>
              <h4 class="font-bold text-red-700">{risk.title}</h4>
              <p class="mt-2 text-sm text-gray-600">{risk.description}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-12">
        <h3 class="text-xl font-bold text-primary mb-6">✅ Lợi Ích Khi Thuê Dịch Vụ Kế Toán Trọn Gói</h3>
        <div class="grid grid-cols-1 gap-5 md:grid-cols-3">
          {hireBenefits.map((b) => (
            <div class="rounded-2xl border border-green-100 bg-green-50 p-6 shadow-sm">
              <div class="text-3xl mb-3">{b.icon}</div>
              <h4 class="font-bold text-green-700">{b.title}</h4>
              <p class="mt-2 text-sm text-gray-600">{b.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Đối tượng phù hợp -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Đối Tượng Phù Hợp Với Dịch Vụ Kế Toán Thuế Của Hoàng Nam
      </h2>
      <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2">
        {targetAudience.map((item) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-6 w-6 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
            <div>
              <h3 class="font-bold text-gray-900">{item.title}</h3>
              <p class="mt-1 text-sm text-gray-600">{item.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Các dịch vụ chính -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Các Dịch Vụ Kế Toán Thuế Của Hoàng Nam
      </h2>
      <div class="mt-8 space-y-4">
        {mainServices.map((service, index) => (
          <div class="flex items-start gap-5 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
            <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {index + 1}
            </span>
            <p class="text-gray-700 pt-2">{service}</p>
          </div>
        ))}
      </div>

      <div class="mt-10">
        <h3 class="text-xl font-bold text-primary mb-4">🎁 Đặc Biệt: Tư Vấn Pháp Lý Miễn Phí</h3>
        <div class="rounded-2xl border border-blue-200 bg-blue-50 p-6">
          <p class="text-gray-700 mb-4">
            Khách hàng sử dụng dịch vụ kế toán thuế của Hoàng Nam được tư vấn miễn phí về:
          </p>
          <ul class="space-y-3">
            {freeConsulting.map((item) => (
              <li class="flex items-start gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                <span class="text-gray-700 text-sm">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Quy trình -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Quy Trình Dịch Vụ Kế Toán Thuế Chuyên Nghiệp Tại Hoàng Nam
      </h2>
      <p class="mt-6 text-gray-700">
        Hoàng Nam thiết kế quy trình làm việc rõ ràng, hiệu quả, gồm 3 bước:
      </p>
      <div class="mt-8 space-y-6">
        {processSteps.map((step, index) => (
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center gap-4 mb-4">
              <span class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-full bg-primary text-lg font-bold text-white">
                {index + 1}
              </span>
              <h3 class="text-lg font-bold text-primary">{step.title}</h3>
            </div>
            <ul class="ml-16 space-y-2">
              {step.details.map((detail) => (
                <li class="flex items-start gap-2 text-gray-600">
                  <span class="text-primary mt-1">•</span>
                  <span>{detail}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bảng giá -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Giá Dịch Vụ Kế Toán Thuế Tại Cần Thơ
      </h2>
      <p class="mt-4 text-gray-600">Minh bạch và hợp lý</p>

      <div class="mt-8 overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="bg-primary text-white">
                <th class="px-4 py-4 font-bold">Số lượng chứng từ<br/><span class="font-normal text-xs">(Hóa đơn mua vào + bán ra)</span></th>
                <th class="px-4 py-4 font-bold text-center">Thương mại<br/>Dịch vụ</th>
                <th class="px-4 py-4 font-bold text-center">Xây dựng<br/>Lắp đặt</th>
                <th class="px-4 py-4 font-bold text-center">Sản xuất<br/>Gia công</th>
              </tr>
            </thead>
            <tbody>
              {pricingTable.map((row, index) => (
                <tr class:list={["border-b border-gray-100 hover:bg-blue-50/50 transition-colors", index % 2 === 1 && "bg-gray-50"]}>
                  <td class="px-4 py-4 font-medium text-gray-800">{row.docs}</td>
                  <td class="px-4 py-4 text-center text-gray-700">{row.tm} {row.tm !== "Thỏa thuận" && "VNĐ/tháng"}</td>
                  <td class="px-4 py-4 text-center text-gray-700">{row.xd} {row.xd !== "Thỏa thuận" && "VNĐ/tháng"}</td>
                  <td class="px-4 py-4 text-center text-gray-700">{row.sx} {row.sx !== "Thỏa thuận" && "VNĐ/tháng"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="mt-4 rounded-r-xl border-l-[6px] border-amber-500 bg-amber-50 px-6 py-4">
        <p class="text-sm text-amber-800">
          <strong>Lưu ý:</strong> Phí dịch vụ chưa bao gồm 10% VAT. Bao gồm đầy đủ các công việc: giao nhận hóa đơn,
          khai thuế, hạch toán và in sổ sách kế toán.
        </p>
      </div>

      <!-- Ưu đãi -->
      <div class="mt-10">
        <h3 class="text-xl font-bold text-primary mb-4">🎁 Ưu Đãi Đặc Biệt</h3>
        <div class="space-y-3">
          {discounts.map((d) => (
            <div class="flex items-start gap-3 rounded-xl border border-green-100 bg-green-50 p-4">
              <span class="text-green-600 font-bold">✓</span>
              <p class="text-gray-700"><strong>{d.method}:</strong> {d.detail}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Cam kết -->
      <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2">
        <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
          <h4 class="font-bold text-primary">🔒 Không phí ẩn</h4>
          <p class="mt-2 text-sm text-gray-600">Báo giá chi tiết ngay từ đầu.</p>
        </div>
        <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm">
          <h4 class="font-bold text-primary">💎 Hỗ trợ giá tốt nhất</h4>
          <p class="mt-2 text-sm text-gray-600">
            Là đại lý chính thức của các nhà cung cấp chữ ký số và hóa đơn điện tử,
            Hoàng Nam cung cấp mức giá ưu đãi và hỗ trợ kỹ thuật 24/7.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tại sao chọn HN -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Tại Sao Chọn Dịch Vụ Kế Toán Thuế Của Hoàng Nam?
      </h2>
      <div class="mt-10 grid grid-cols-1 gap-8 md:grid-cols-2">
        <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm transition-all hover:shadow-lg">
          <h3 class="text-xl font-bold text-primary">💰 Tiết Kiệm Chi Phí và Thời Gian</h3>
          <ul class="mt-4 space-y-2 text-sm text-gray-600">
            <li>• <strong>Không cần nhân sự kế toán:</strong> Tiết kiệm chi phí tuyển dụng, đào tạo và trả lương.</li>
            <li>• <strong>Hiệu quả cao:</strong> Đội ngũ chuyên gia đảm bảo xử lý chính xác, đúng hạn.</li>
