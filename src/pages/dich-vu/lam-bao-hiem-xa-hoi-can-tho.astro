---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProcessSteps from "@/components/homepage/ProcessSteps.astro";
import CTABanner from "@/components/homepage/CTABanner.astro";

// Use an image from assets if downloading or use external/placeholder
import imgBHXH from "@/assets/images/services/lam-bhxh.png";

const metadata = {
  title: "Dịch Vụ Làm Bảo Hiểm Xã Hội Tại Cần Thơ | Kế Toán Hoàng Nam",
  description:
    "Hoàng Nam cung cấp Dịch vụ làm Bảo hiểm xã hội (BHXH) trọn gói tại Cần Thơ. Đăng ký lao động, cấp mã đơn vị, báo tăng giảm, chế độ thai sản chuyên nghiệp, nhanh chóng.",
};

const workingProcess = [
  {
    title: "Đăng ký bảo hiểm xã hội lần đầu",
    description: "Hướng dẫn đăng ký bảo hiểm xã hội lần đầu, đăng ký cấp thẻ BHYT, làm sổ BHXH.",
  },
  {
    title: "Báo giảm / Báo tăng",
    description: "Thực hiện hồ sơ khai báo tăng hoặc giảm lao động đúng quy định pháp luật.",
  },
  {
    title: "Chế độ thai sản",
    description: "Thực hiện các thủ tục giải quyết chế độ thai sản cho người lao động nhanh chóng.",
  },
  {
    title: "Chế độ tử tuất",
    description: "Giải quyết các hồ sơ hưởng chế độ tử tuất đối với người lao động.",
  },
  {
    title: "Chốt sổ BHXH",
    description: "Thực hiện quy trình chốt sổ khi doanh nghiệp cho lao động thôi việc.",
  },
  {
    title: "Đối chiếu hàng quý",
    description: "Thực hiện đối chiếu số tiền đóng bảo hiểm định kỳ với cơ quan BHXH.",
  },
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Làm Bảo Hiểm Xã Hội Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Đảm bảo phúc lợi cho người lao động, giúp doanh nghiệp yên tâm phát triển.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24 bg-white relative overflow-hidden">
    <div class="container mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative order-2 lg:order-1">
          <div class="relative rounded-2xl overflow-hidden shadow-2xl z-10 group">
             <!-- Vẫn gọi src img -->
            <img 
              src={imgBHXH.src}
              alt="Dịch vụ làm Bảo hiểm xã hội tại Cần Thơ" 
              class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 border-4 border-white/20 rounded-2xl z-20 pointer-events-none"></div>
          </div>
          <!-- Decorative elements -->
          <div class="absolute -top-6 -left-6 w-24 h-24 bg-primary/20 rounded-full blur-2xl -z-10"></div>
          <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-secondary/20 rounded-full blur-3xl -z-10"></div>
          <div class="absolute top-1/2 -ml-8 w-16 h-16 bg-accent/10 rounded-lg rotate-12 -z-10"></div>
        </div>
        
        <div class="space-y-6 order-1 lg:order-2">
          <div class="inline-block rounded-lg bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
            Giải Pháp Quản Lý
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-accent">Công Cụ Hỗ Trợ Đắc Lực Cho Doanh Nghiệp</h2>
          <div class="space-y-4 text-gray-700 leading-relaxed text-lg">
            <p>
              Phần mềm bảo hiểm xã hội trở thành một trong những công cụ hỗ trợ đắc lực cho các đơn vị, doanh nghiệp trong việc kê khai bảo hiểm xã hội cho người lao động.
            </p>
            <p>
              Hiểu được tầm quan trọng đó, <strong class="text-primary font-semibold">Hoàng Nam cung cấp Dịch vụ làm Bảo hiểm xã hội (BHXH)</strong> tại Cần Thơ cho mọi doanh nghiệp. Đây cũng là dịch vụ chuyên nghiệp của công ty Hoàng Nam tại khu vực Cần Thơ.
            </p>
            <p>
              Đội ngũ nhân sự Kế toán của Hoàng Nam cung cấp dịch vụ làm BHXH, dịch vụ tiền lương, dịch vụ lao động cho tất cả các doanh nghiệp trong cả nước nói chung và Cần Thơ nói riêng.
            </p>
            <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-lg mt-6 text-gray-800">
              <span class="font-semibold text-blue-700">Bạn là cá nhân hay doanh nghiệp đang gặp vướng mắc?</span><br />
              Về bảo hiểm xã hội, bảo hiểm y tế, bảo hiểm thất nghiệp và lao động tiền lương hãy liên hệ ngay với Hoàng Nam. Chúng tôi sẽ thay mặt bạn giải quyết các thủ tục pháp lý.
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BẢNG GIÁ ĐĂNG KÝ -->
  <section class="py-16 md:py-20 bg-gray-50 border-y border-gray-100">
    <div class="container mx-auto px-6 max-w-5xl">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-bold text-accent mb-4">Bảng Phí Đăng Ký Lao Động – Bảo Hiểm Xã Hội</h2>
        <p class="text-gray-600">(Bao gồm Tư vấn, nộp và nhận hồ sơ)</p>
      </div>

      <div class="overflow-x-auto bg-white rounded-xl shadow-md">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-primary text-white">
              <th scope="col" class="py-4 px-6 border-b border-primary-dark font-semibold text-center w-16">STT</th>
              <th scope="col" class="py-4 px-6 border-b border-primary-dark font-semibold">SỐ LƯỢNG NGƯỜI LAO ĐỘNG</th>
              <th scope="col" class="py-4 px-6 border-b border-primary-dark font-semibold text-center" colspan="3">BIỂU PHÍ TỪNG NHÓM (VNĐ)</th>
            </tr>
            <tr class="bg-teal-600 text-white text-sm">
                <th class="py-3 px-6 border-b border-teal-700 text-center"></th>
                <th class="py-3 px-6 border-b border-teal-700"></th>
                <th class="py-3 px-6 border-b border-teal-700 text-center border-l border-teal-500">Cấp Mã Đơn Vị</th>
                <th class="py-3 px-6 border-b border-teal-700 text-center border-l border-teal-500">Báo Tăng/ Giảm</th>
                <th class="py-3 px-6 border-b border-teal-700 text-center border-l border-teal-500">Thai Sản</th>
            </tr>
          </thead>
          <tbody class="text-gray-700">
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="py-4 px-6 border-b border-gray-200 text-center font-medium">1</td>
              <td class="py-4 px-6 border-b border-gray-200 font-semibold text-accent">1 - 2 Lao động</td>
              <td class="py-4 px-6 border-b border-gray-200 text-center text-primary font-bold text-lg border-l border-gray-100" rowspan="3">1.000.000</td>
              <td class="py-4 px-6 border-b border-gray-200 text-center font-medium border-l border-gray-100">600.000</td>
              <td class="py-4 px-6 border-b border-gray-200 text-center text-secondary font-bold border-l border-gray-100" rowspan="3">800.000<span class="text-sm font-normal text-gray-500"><br/>/ người</span></td>
            </tr>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="py-4 px-6 border-b border-gray-200 text-center font-medium">2</td>
              <td class="py-4 px-6 border-b border-gray-200 font-semibold text-accent">3 - 4 Lao động</td>
              <td class="py-4 px-6 border-b border-gray-200 text-center font-medium border-l border-gray-100">500.000</td>
            </tr>
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="py-4 px-6 border-b border-gray-200 text-center font-medium">3</td>
              <td class="py-4 px-6 border-b border-gray-200 font-semibold text-accent">5 - 6 Lao động</td>
              <td class="py-4 px-6 border-b border-gray-200 text-center font-medium border-l border-gray-100">400.000</td>
            </tr>
             <tr class="hover:bg-gray-50 transition-colors bg-blue-50/50">
              <td class="py-4 px-6 border-b border-gray-200 text-center font-medium">4</td>
              <td class="py-4 px-6 border-b border-gray-200 font-semibold text-accent">&gt;6 Lao động</td>
              <td class="py-4 px-6 border-b border-gray-200 text-center font-bold text-accent italic border-l border-gray-100" colspan="3">Thỏa thuận trực tiếp</td>
            </tr>
          </tbody>
        </table>
      </div>
      
      <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
             <h4 class="font-bold text-red-600 mb-2 flex items-center"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg> Lưu ý quan trọng</h4>
             <ul class="text-sm text-gray-600 space-y-2">
                 <li class="flex items-start"><svg class="h-4 w-4 text-primary mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Dịch vụ Đăng ký lao động – BHXH trên đã bao gồm: Chuẩn bị hồ sơ, nộp và nhận kết quả.</li>
                 <li class="flex items-start"><svg class="h-4 w-4 text-primary mr-2 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Phí dịch vụ trên <strong>chưa bao gồm 10% VAT</strong>.</li>
             </ul>
          </div>
          <div class="bg-gradient-to-br from-green-50 to-emerald-50 p-6 rounded-xl shadow-sm border border-green-100 relative overflow-hidden">
             <div class="absolute -right-4 -top-4 opacity-10">
                 <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7" /></svg>
             </div>
             <h4 class="font-bold text-green-700 mb-2 flex items-center relative z-10"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg> Ưu đãi đặc biệt</h4>
             <p class="text-sm text-green-800 leading-relaxed font-medium relative z-10">Đối với Khách hàng sử dụng Dịch vụ Khai thuế hoặc Kế toán của Hoàng Nam sẽ được <strong>miễn phí hoàn toàn</strong> phí 1 NLĐ Báo tăng hoặc Báo giảm (chỉ tính phí cấp Mã đơn vị nếu có).</p>
          </div>
      </div>
    </div>
  </section>

  <!-- Cam kết & Lợi ích -->
  <section class="py-16 md:py-24 bg-white relative">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
        <!-- Cột 1 -->
        <div>
          <h2 class="text-3xl font-bold text-accent mb-8 relative inline-block">
            Cam Kết Của Dịch Vụ Hoàng Nam
            <div class="absolute -bottom-3 left-0 w-1/2 h-1 bg-secondary rounded-full"></div>
          </h2>
          <ul class="space-y-4">
             <li class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:shadow-md transition-shadow">
                <div class="flex-shrink-0 mt-1"><div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg></div></div>
                <div><h4 class="font-bold text-gray-900">Bàn giao tận tay</h4><p class="text-gray-600 text-sm mt-1">Thực hiện giao sổ BHXH, thẻ BHYT cho người lao động an toàn.</p></div>
            </li>
            <li class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:shadow-md transition-shadow">
                <div class="flex-shrink-0 mt-1"><div class="w-8 h-8 rounded-full bg-green-100 flex items-center justify-center text-green-600"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg></div></div>
                <div><h4 class="font-bold text-gray-900">Tối ưu mức đóng</h4><p class="text-gray-600 text-sm mt-1">Đảm bảo mức đóng BHXH, BHYT, BHTN là thấp nhất cho doanh nghiệp.</p></div>
            </li>
            <li class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:shadow-md transition-shadow">
                <div class="flex-shrink-0 mt-1"><div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-purple-600"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg></div></div>
                <div><h4 class="font-bold text-gray-900">Cung cấp văn bản pháp luật</h4><p class="text-gray-600 text-sm mt-1">Cung cấp các văn bản liên quan mới nhất theo yêu cầu của doanh nghiệp.</p></div>
            </li>
            <li class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:shadow-md transition-shadow">
                <div class="flex-shrink-0 mt-1"><div class="w-8 h-8 rounded-full bg-amber-100 flex items-center justify-center text-amber-600"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg></div></div>
                <div><h4 class="font-bold text-gray-900">Hướng dẫn chu đáo</h4><p class="text-gray-600 text-sm mt-1">Hướng dẫn chi tiết các thủ tục sau khi nhận sổ BHXH và thẻ BHYT.</p></div>
            </li>
            <li class="flex gap-4 p-4 rounded-xl bg-gray-50 border border-gray-100 hover:shadow-md transition-shadow">
                <div class="flex-shrink-0 mt-1"><div class="w-8 h-8 rounded-full bg-teal-100 flex items-center justify-center text-teal-600"><svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg></div></div>
                <div><h4 class="font-bold text-gray-900">Tư vấn miễn phí sau dịch vụ</h4><p class="text-gray-600 text-sm mt-1">Tư vấn miễn phí về các qui định về BHXH, BHYT, BHTN kể cả sau khi đã hoàn tất thủ tục.</p></div>
            </li>
          </ul>
        </div>

        <!-- Cột 2 -->
        <div>
           <div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 h-full">
              <h2 class="text-3xl font-bold text-accent mb-6">Tại Sao Bạn Nên Thuê Dịch Vụ Của Chúng Tôi?</h2>
              <div class="space-y-4 text-gray-700">
                <p>Với lợi thế là công ty chuyên hoạt động trong lĩnh vực tài chính kế toán, dịch vụ nhân sự, đội ngũ của Hoàng Nam đảm bảo mang lại gói dịch vụ hoàn hảo nhất.</p>
                <p>Công ty Hoàng Nam được thành lập bởi các chuyên gia tư vấn có hơn <span class="font-bold text-primary">8-15 năm kinh nghiệm</span> thực tế, xử lý hàng ngàn hồ sơ kế toán và BHXH.</p>
                <p>Dù ở bất cứ lĩnh vực nào thì dịch vụ chuyên nghiệp, chuyên môn hoá cao luôn dẫn đến <strong class="text-secondary text-lg">chi phí thấp nhất và chất lượng tốt nhất</strong>.</p>
                
                <h3 class="font-bold text-lg text-accent mt-6 mb-3">Dịch Vụ Của Chúng Tôi Sẽ:</h3>
                <ul class="space-y-3">
                   <li class="flex items-start">
                     <svg class="h-5 w-5 text-green-500 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                     <span>Tư vấn các quy định về pháp luật, thủ tục thực hiện nghĩa vụ bảo hiểm.</span>
                   </li>
                   <li class="flex items-start">
                     <svg class="h-5 w-5 text-green-500 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                     <span>Tư vấn hồ sơ và các giấy tờ liên quan đến BHXH.</span>
                   </li>
                   <li class="flex items-start">
                     <svg class="h-5 w-5 text-green-500 mr-2 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                     <span>Thay mặt khách hàng chuẩn bị tài liệu và nộp hồ sơ tại cơ quan.</span>
                   </li>
                </ul>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps 
    title="Những Công Việc Hoàng Nam Xử Lý Thay Bạn"
    subtitle="Quy trình 6 bước khép kín giúp giải quyết mọi vấn đề về Bảo hiểm cho người lao động."
    steps={workingProcess} 
  />

  <!-- Info Section -->
  <section class="py-16 bg-primary/5">
    <div class="container mx-auto px-6 max-w-4xl text-center">
        <h2 class="text-2xl font-bold text-accent mb-6">Liên Hệ Hoàng Nam - Chi Nhánh Cần Thơ</h2>
        <p class="text-gray-700 mb-8">
            Ngoài dịch vụ làm bảo hiểm xã hội và tiền lương, Hoàng Nam còn cung cấp dịch vụ kế toán thuế, làm báo cáo tài chính, thành lập doanh nghiệp trên mọi loại hình tại Cần Thơ.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-left">
            <div class="bg-white p-6 rounded-xl shadow-sm">
                <h4 class="font-bold text-lg text-primary mb-2">Trụ Sở Kế Toán</h4>
                <p class="text-gray-600 mb-1"><strong>Địa chỉ:</strong> 03 Đ. Quản Trọng Hoàng, Xuân Khánh, Ninh Kiều, Cần Thơ, Việt Nam</p>
