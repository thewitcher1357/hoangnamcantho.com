---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import CTABanner from "@/components/homepage/CTABanner.astro";
import heroImage from "@/assets/images/services/thay-doi-dia-chi-tru-so.jpg";
import flowImage from "@/assets/images/services/quy-trinh-thay-doi-dia-chi.png";

const metadata = {
  title: "Dịch Vụ Thay Đổi Địa Chỉ Trụ Sở Công Ty Tại Cần Thơ – 24-48H",
  description:
    "Hoàng Nam cung cấp dịch vụ thay đổi địa chỉ trụ sở công ty tại Cần Thơ trọn gói. Cập nhật thuế, hóa đơn, con dấu nhanh chóng trong 24-48 giờ. Hotline 091.888.31.79.",
};

const risks = [
  { icon: "⚠️", title: "Phạt hành chính", desc: "Theo Nghị định 122/2021/NĐ-CP, doanh nghiệp không thông báo thay đổi địa chỉ trụ sở có thể bị phạt từ 5-10 triệu đồng." },
  { icon: "📄", title: "Rủi ro về thuế và hóa đơn", desc: "Địa chỉ không khớp có thể dẫn đến việc hóa đơn bị từ chối hoặc gặp rắc rối với cơ quan thuế." },
  { icon: "📉", title: "Ảnh hưởng uy tín", desc: "Địa chỉ không chính xác gây khó khăn trong giao dịch với đối tác, làm giảm độ tin cậy." },
];

const benefits = [
  { icon: "⚖️", title: "Tuân thủ pháp luật", desc: "Cập nhật địa chỉ trên Giấy phép kinh doanh đảm bảo doanh nghiệp hoạt động hợp pháp." },
  { icon: "📍", title: "Vị trí chiến lược", desc: "Di dời trụ sở đến khu vực thuận lợi hơn tại Cần Thơ giúp tiếp cận khách hàng." },
  { icon: "🏆", title: "Tăng uy tín thương hiệu", desc: "Địa chỉ chính xác, phù hợp giúp xây dựng hình ảnh chuyên nghiệp với đối tác." },
];

const changeTypes = [
  { title: "Cùng quận/huyện tại Cần Thơ", desc: "Chỉ cần cập nhật địa chỉ mới với Sở Kế hoạch và Đầu tư (KHĐT)." },
  { title: "Khác quận/huyện tại Cần Thơ", desc: "Yêu cầu thêm thủ tục chuyển sổ thuế giữa các chi cục thuế." },
  { title: "Chuyển sang tỉnh/thành khác", desc: "Cần thực hiện thêm các bước thông báo với cơ quan thuế và cập nhật con dấu." },
];

const docsRequired = [
  "Thông báo thay đổi địa chỉ trụ sở (theo mẫu Nghị định 01/2021/NĐ-CP).",
  "Biên bản họp của Hội đồng thành viên/Đại hội đồng cổ đông về việc di dời trụ sở.",
  "Quyết định thay đổi địa chỉ do chủ sở hữu/Hội đồng quản trị ban hành.",
  "Giấy chứng nhận đăng ký doanh nghiệp (bản sao công chứng).",
  "Giấy ủy quyền (nếu sử dụng dịch vụ của Hoàng Nam).",
];

const processSteps = [
  {
    title: "Chuẩn bị và nộp hồ sơ tại Sở KHĐT Cần Thơ",
    items: [
      "Soạn thảo và nộp hồ sơ qua Cổng thông tin Đăng ký doanh nghiệp quốc gia hoặc trực tiếp.",
      "Theo dõi tiến độ, xử lý sửa đổi (nếu có).",
    ],
  },
  {
    title: "Xử lý thủ tục thuế và hoàn thuế khi chuyển trụ sở",
    items: [
      "Thông báo thay đổi địa chỉ với cơ quan thuế.",
      "Hỗ trợ hoàn thuế khi chuyển trụ sở (nếu có).",
    ],
  },
  {
    title: "Cập nhật thông tin doanh nghiệp trên Giấy phép kinh doanh",
    items: [
      "Nhận Giấy chứng nhận đăng ký doanh nghiệp mới trong 3-5 ngày.",
      "Cập nhật con dấu, hóa đơn điện tử, chữ ký số, và BHXH.",
    ],
  },
];

const pricing = [
  { name: "Công ty TNHH", range: "500.000 – 800.000 đ" },
  { name: "Công ty cổ phần", range: "700.000 – 1.200.000 đ" },
];

const faqs = [
  {
    q: "Hồ sơ thay đổi địa chỉ công ty gồm những gì?",
    a: "Hồ sơ bao gồm thông báo thay đổi địa chỉ, biên bản họp, quyết định thay đổi, và bản sao Giấy chứng nhận đăng ký doanh nghiệp. Hoàng Nam sẽ hỗ trợ soạn thảo chuẩn mẫu.",
  },
  {
    q: "Thay đổi địa chỉ công ty mất bao lâu?",
    a: "Thời gian xử lý tại Sở KHĐT Cần Thơ thường từ 3-5 ngày làm việc. Với dịch vụ của chúng tôi, bạn có thể nhận kết quả sớm hơn trong 24-48 giờ.",
  },
  {
    q: "Có thể nộp hồ sơ online không?",
    a: "Có, bạn có thể nộp hồ sơ qua Cổng thông tin Đăng ký doanh nghiệp quốc gia. Hoàng Nam sẽ thay bạn thực hiện toàn bộ quy trình này.",
  },
  {
    q: "Thay đổi địa chỉ khác quận/huyện có phức tạp không?",
    a: "Thay đổi địa chỉ khác quận/huyện tại Cần Thơ yêu cầu thêm thủ tục chuyển sổ thuế. Chúng tôi sẽ hỗ trợ xử lý nhanh chóng, đảm bảo không gián đoạn hoạt động kinh doanh.",
  },
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Thay Đổi Địa Chỉ Trụ Sở Công Ty Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Trọn Gói – 24-48 Giờ – Hỗ Trợ Cập Nhật Thuế, Con Dấu, Hóa Đơn
      </p>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Bạn đang cần <strong class="text-primary">dịch vụ thay đổi địa chỉ trụ sở công ty tại Cần Thơ</strong> để di dời trụ sở nhanh chóng, đúng luật và tiết kiệm thời gian? <strong class="text-primary">Hoàng Nam</strong> cung cấp giải pháp trọn gói, giúp doanh nghiệp hoàn tất <strong>thủ tục thay đổi địa chỉ công ty</strong> chỉ trong 24-48 giờ. Chúng tôi đảm bảo xử lý hồ sơ chính xác, hỗ trợ cập nhật thuế, hóa đơn, con dấu, và các thủ tục liên quan.
        </p>
      </div>
      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Dịch vụ thay đổi địa chỉ trụ sở công ty tại Cần Thơ"
          width={750}
          height={500}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Rủi ro -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Không Thay Đổi Địa Chỉ Kịp Thời? Doanh Nghiệp Có Thể Bị Phạt!
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {risks.map((r) => (
          <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
            <div class="mb-3 text-3xl">{r.icon}</div>
            <strong class="block text-sm text-primary">{r.title}</strong>
            <p class="mt-2 text-xs text-gray-600">{r.desc}</p>
          </div>
        ))}
      </div>

      <h3 class="mt-8 text-xl font-bold text-primary">Tại Sao Cần Thay Đổi Địa Chỉ Công Ty?</h3>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {benefits.map((b) => (
          <div class="rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
            <div class="text-2xl">{b.icon}</div>
            <strong class="mt-2 block text-sm text-primary">{b.title}</strong>
            <p class="mt-1 text-xs text-gray-600">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Các trường hợp thay đổi -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Hướng Dẫn Thay Đổi Địa Chỉ Trụ Sở Tại Cần Thơ
      </h2>
      <h3 class="mt-6 text-xl font-bold text-primary">Các Trường Hợp Thay Đổi Địa Chỉ</h3>
      <div class="mt-4 space-y-3">
        {changeTypes.map((c, i) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-gray-50 p-5 shadow-sm">
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">{i + 1}</span>
            <div>
              <strong class="text-primary">{c.title}</strong>
              <span class="text-gray-600">: {c.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <h3 class="mt-8 text-xl font-bold text-primary">Hồ Sơ Cần Chuẩn Bị Để Đăng Ký Thay Đổi Địa Chỉ</h3>
      <div class="mt-4 space-y-3">
        {docsRequired.map((doc) => (
          <div class="flex items-start gap-3 rounded-xl border border-gray-100 bg-white p-4 shadow-sm">
            <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-primary" />
            <p class="text-sm text-gray-700">{doc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quy trình -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h3 class="text-xl font-bold text-primary">Quy Trình Thay Đổi Địa Chỉ Công Ty Tại Cần Thơ</h3>
      <div class="my-6 overflow-hidden rounded-2xl shadow-md">
        <Image
          src={flowImage}
          alt="Quy Trình Thay Đổi Địa Chỉ Công Ty Tại Cần Thơ"
          width={840}
          height={552}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col gap-5">
        {processSteps.map((step, i) => (
          <div class="flex items-start gap-5 rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
            <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {i + 1}
            </span>
            <div>
              <h4 class="font-bold text-primary">{step.title}</h4>
              <ul class="mt-2 space-y-1 text-gray-600">
                {step.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary/50" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Chi phí -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Chi Phí Thay Đổi Địa Chỉ Công Ty – Minh Bạch &amp; Hợp Lý
      </h2>
      <div class="mt-6 overflow-hidden rounded-2xl border border-gray-200 shadow-sm">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="bg-primary text-white">
              <th class="px-4 py-3 font-semibold md:px-6">Loại hình doanh nghiệp</th>
              <th class="px-4 py-3 text-right font-semibold md:px-6">Phí dịch vụ</th>
            </tr>
          </thead>
          <tbody>
            {pricing.map((p, i) => (
              <tr class:list={[i % 2 === 0 ? "bg-white" : "bg-gray-50", "border-t border-gray-100"]}>
                <td class="px-4 py-3 md:px-6">{p.name}</td>
                <td class="px-4 py-3 text-right font-semibold text-primary md:px-6">{p.range}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <div class="mt-4 rounded-r-xl border-l-[6px] border-amber-400 bg-amber-50 px-6 py-4">
        <p class="text-sm text-amber-800">
          <strong>Lưu ý:</strong> Phí nhà nước <strong>200.000 đ</strong> (nộp Sở KHĐT) + <strong>300.000 đ</strong> (khắc dấu, nếu cần). Cam kết không phát sinh chi phí ẩn.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Hỏi Đáp Nhanh – Giải Đáp Mọi Thắc Mắc
      </h2>
      <div class="mt-6 space-y-4">
        {faqs.map((faq) => (
          <div class="rounded-2xl border-l-[5px] border-primary bg-white p-6 shadow-sm">
            <h4 class="font-bold text-primary">{faq.q}</h4>
            <p class="mt-2 text-sm text-gray-700">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Khu vực hỗ trợ -->
  <section class="bg-white py-12">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border-2 border-dashed border-primary bg-blue-50 p-8 text-center">
        <p class="text-lg font-bold text-primary">
          📍 Hỗ trợ tận nơi tại Cần Thơ:{" "}
          <span class="font-normal text-gray-700">
            Ninh Kiều, Cái Răng, Bình Thủy, Ô Môn, Thốt Nốt, Phong Điền, Cờ Đỏ, Vĩnh Thạnh, Thới Lai.
          </span>
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border border-primary/20 bg-blue-50 p-8">
        <h2 class="text-xl font-extrabold text-primary">
          📞 Gọi Ngay Để Được Tư Vấn Miễn Phí Và Xử Lý Thủ Tục Thay Đổi Địa Chỉ Trong 24-48H!
        </h2>
        <div class="mt-6 space-y-2 text-sm text-gray-700">
          <p>📌 <strong>Địa chỉ:</strong> 462 Lê Hồng Nhi, KV1, P. Ba Láng, Q. Cái Răng, Tp. Cần Thơ</p>
          <p>📞 <strong>Hotline:</strong> 091.888.31.79</p>
          <p>📧 <strong>Email:</strong> <a href="mailto:tructuyenhoangnam@gmail.com" class="text-primary underline">tructuyenhoangnam@gmail.com</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Gọi Ngay 091.888.31.79 – Thay Đổi Địa Chỉ Công Ty Trong 24-48H!"
    subtitle="Hoàng Nam – Gỡ rối, kết nối, đảm bảo thông suốt mọi thủ tục pháp lý doanh nghiệp tại Cần Thơ."
  />
</BaseLayout>
