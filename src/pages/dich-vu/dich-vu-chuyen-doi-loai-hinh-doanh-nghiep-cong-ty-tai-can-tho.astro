---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProcessSteps from "@/components/homepage/ProcessSteps.astro";
import CTABanner from "@/components/homepage/CTABanner.astro";
import ServiceFeature from "@/components/services/ServiceFeature.astro";

// Images from assets
import imgHero from "@/assets/images/services/chuyen-doi-loai-hinh-dn.jpg";
import imgHoSo from "@/assets/images/services/ho-so-chuyen-doi-loai-hinh.png";

const metadata = {
  title: "Dịch Vụ Chuyển Đổi Loại Hình Doanh Nghiệp Tại Cần Thơ | Kế Toán Hoàng Nam",
  description:
    "Hoàng Nam hỗ trợ Chuyển đổi loại hình doanh nghiệp, công ty tại Cần Thơ trọn gói, thủ tục nhanh chóng từ 3-5 ngày, tiết kiệm chi phí, tư vấn miễn phí tận tình.",
};

const workingProcess = [
  {
    title: "Tư vấn & Chuẩn bị hồ sơ",
    description: "Nhân viên viên Hoàng Nam tư vấn, hướng dẫn quý khách hàng và chuẩn bị hồ sơ chuyển đổi loại hình.",
  },
  {
    title: "Nộp hồ sơ Online",
    description: "Nhân viên Hoàng Nam nộp hồ sơ Online tại Phòng đăng ký kinh doanh Sở kế hoạch và đầu tư.",
  },
  {
    title: "Nhận & Bàn giao Giấy phép",
    description: "Nhân viên Hoàng Nam nhận giấy đăng ký kinh doanh tại Sở và tiến hành trả giấy phép cho khách hàng.",
  },
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Chuyển Đổi Loại Hình Doanh Nghiệp Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Nhanh chóng - Tiết kiệm - Đúng luật. Trọn gói từ A-Z chỉ từ 3-5 ngày làm việc.
      </p>
    </div>
  </section>

  <!-- Intro & Tại sao cần phải chuyển đổi -->
  <section class="py-16 md:py-24 bg-white relative overflow-hidden">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="relative order-2 lg:order-1 rounded-2xl overflow-hidden shadow-2xl group">
             <img 
              src={imgHero.src}
              alt="Dịch vụ chuyển đổi loại hình doanh nghiệp tại Cần Thơ" 
              class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 border-4 border-white/20 rounded-2xl z-20 pointer-events-none"></div>
        </div>
        
        <div class="space-y-6 order-1 lg:order-2">
          <div class="inline-block rounded-lg bg-primary/10 px-3 py-1 text-sm font-semibold text-primary">
            Giải Pháp Tối Ưu
          </div>
          <h2 class="text-3xl font-bold text-accent">Tầm quan trọng đặc biệt của thủ tục chuyển đổi loại hình đối với Doanh nghiệp</h2>
          <div class="space-y-4 text-gray-700 leading-relaxed text-lg">
            <p>
              Việc chuyển đổi loại hình không chỉ là thủ tục pháp lý bắt buộc khi có sự thay đổi về thành viên góp vốn hay cơ cấu sở hữu, mà còn là đòn bẩy chiến lược để tận dụng linh hoạt các ưu đãi thuế quan, mở rộng phương thức huy động vốn linh hoạt từ thị trường, từ đó tạo nền tảng vững chắc cho sự tăng trưởng bền vững của tổ chức.
            </p>
            <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-lg mt-6">
              <h3 class="font-bold text-blue-800 mb-2">Các trường hợp cần phải thực hiện thủ tục chuyển đổi loại hình công ty:</h3>
              <ul class="list-disc pl-5 space-y-1 text-blue-900">
                  <li>Công ty Cổ phần (CT Cổ phần) chuyển đổi sang Công ty Trách nhiệm hữu hạn (CT TNHH).</li>
                  <li>Công ty Trách nhiệm hữu hạn (CT TNHH) chuyển đổi thành Công ty Cổ phần (CT CP).</li>
                  <li>Doanh nghiệp tư nhân (DNTN) chuyển đổi thành Công ty Trách nhiệm hữu hạn (CT TNHH).</li>
              </ul>
            </div>
            <p>
              Tùy thuộc vào nhu cầu và phương hướng phát triển của mỗi doanh nghiệp có thể chuyển đổi loại hình nào theo quy định <strong>Luật Doanh nghiệp 2020 Cần Thơ</strong>. Nếu doanh nghiệp tự thực hiện sẽ gặp nhiều khó khăn, làm chậm tiến độ nhận giấy phép. Với hơn <strong class="text-primary font-semibold">10 năm kinh nghiệm</strong> thực tiễn, Hoàng Nam tự tin giải quyết nhanh gọn với thời gian <strong>chỉ từ 3 – 5 ngày làm việc</strong>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Rủi ro & Lợi ích -->
  <section class="py-16 bg-gray-50 border-y border-gray-100">
    <div class="container mx-auto px-6 max-w-6xl">
       <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
           <div class="bg-white p-8 rounded-2xl shadow-sm border border-red-100">
              <h3 class="text-2xl font-bold text-red-600 mb-6 flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                  Rủi ro nếu không chuyển đổi?
              </h3>
              <ul class="space-y-4">
                  <li class="flex items-start">
                      <svg class="h-6 w-6 text-red-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                      <span class="text-gray-700"><strong>Giới hạn khả năng phát triển:</strong> Bị hạn chế huy động vốn, phát hành cổ phiếu, gặp nhiều rào cản khi mở rộng mạng lưới, hợp tác chiến lược, hay thu hút nhân tài.</span>
                  </li>
                  <li class="flex items-start">
                      <svg class="h-6 w-6 text-red-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                      <span class="text-gray-700"><strong>Mất nhiều lợi thế pháp luật:</strong> Có thể chịu rủi ro pháp lý cao hoặc không được hưởng ưu đãi thuế tối ưu. Việc tái đầu tư gặp nhiều rào cản từ thủ tục.</span>
                  </li>
                  <li class="flex items-start">
                      <svg class="h-6 w-6 text-red-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                      <span class="text-gray-700"><strong>Nguy cơ bị phạt:</strong> Hoạt động kinh doanh bị gián đoạn và đối mặt với rủi ro bị phạt trong kinh doanh. </span>
                  </li>
              </ul>
           </div>

           <div class="bg-gradient-to-br from-green-50 to-emerald-50 p-8 rounded-2xl shadow-sm border border-green-100">
              <h3 class="text-2xl font-bold text-green-700 mb-6 flex items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                  Lợi ích khi chuyển đổi loại hình
              </h3>
              <ul class="space-y-4">
                  <li class="flex items-start">
                      <svg class="h-6 w-6 text-green-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span class="text-gray-700"><strong>Mở ra cánh cửa mới:</strong> Thiết lập nền móng vững chắc cho quá trình chuyển đổi mô hình kinh doanh một cách hiệu quả và liền mạch.</span>
                  </li>
                  <li class="flex items-start">
                      <svg class="h-6 w-6 text-green-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span class="text-gray-700"><strong>Tính đa dạng về vốn:</strong> Cho phép doanh nghiệp thu hút thêm đối tác tài chính mới, giúp tăng cường nguồn vốn một cách linh hoạt.</span>
                  </li>
                  <li class="flex items-start">
                      <svg class="h-6 w-6 text-green-500 mr-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                      <span class="text-gray-700"><strong>Ổn định tổ chức:</strong> Nâng cấp cấu trúc quản trị nhằm tối ưu hóa hoạt động, đảm bảo sự linh hoạt và khả năng ứng phó với mọi thay đổi của trị trường.</span>
                  </li>
              </ul>
           </div>
       </div>
    </div>
  </section>

  <!-- Hồ sơ cần chuẩn bị -->
  <section class="py-16 md:py-24 bg-white relative">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-bold text-accent mb-6">Hồ sơ chuyển đổi loại hình doanh nghiệp bao gồm?</h2>
          <p class="text-gray-700 mb-6">Doanh nghiệp khi muốn thay đổi loại hình hoạt động cần chuẩn bị các giấy tờ sau:</p>
          
          <ul class="space-y-3 mb-6 bg-gray-50 p-6 rounded-xl border border-gray-100">
             <li class="flex items-start">
                 <div class="flex-shrink-0 mt-1 w-6 h-6 flex items-center justify-center bg-primary text-white rounded-full text-xs font-bold mr-3">1</div>
                 <p class="text-gray-700">Giấy đề nghị chuyển đổi và chứng minh nhân dân/CCCD của người thành lập công ty.</p>
             </li>
             <li class="flex items-start">
                 <div class="flex-shrink-0 mt-1 w-6 h-6 flex items-center justify-center bg-primary text-white rounded-full text-xs font-bold mr-3">2</div>
                 <p class="text-gray-700">Điều lệ công ty theo loại hình chuyển đổi.</p>
             </li>
             <li class="flex items-start">
                 <div class="flex-shrink-0 mt-1 w-6 h-6 flex items-center justify-center bg-primary text-white rounded-full text-xs font-bold mr-3">3</div>
                 <p class="text-gray-700">Bản sao công chứng điều lệ công ty đã ban hành trước đó.</p>
             </li>
             <li class="flex items-start">
                 <div class="flex-shrink-0 mt-1 w-6 h-6 flex items-center justify-center bg-primary text-white rounded-full text-xs font-bold mr-3">4</div>
                 <p class="text-gray-700">Biên bản quyết định của doanh nghiệp về việc chuyển đổi loại hình.</p>
             </li>
             <li class="flex items-start">
                 <div class="flex-shrink-0 mt-1 w-6 h-6 flex items-center justify-center bg-primary text-white rounded-full text-xs font-bold mr-3">5</div>
                 <p class="text-gray-700">Giấy cam kết về việc giải quyết các khoản nợ sau khi chuyển đổi.</p>
             </li>
             <li class="flex items-start">
                 <div class="flex-shrink-0 mt-1 w-6 h-6 flex items-center justify-center bg-primary text-white rounded-full text-xs font-bold mr-3">6</div>
                 <p class="text-gray-700">Báo cáo tài chính, quyết toán số dư trước khi tiến hành chuyển đổi.</p>
             </li>
             <li class="flex items-start">
                 <div class="flex-shrink-0 mt-1 w-6 h-6 flex items-center justify-center bg-primary text-white rounded-full text-xs font-bold mr-3">7</div>
                 <p class="text-gray-700">Giấy chứng nhận đăng ký kinh doanh và một số giấy tờ khác có liên quan.</p>
             </li>
          </ul>
          
          <div class="bg-amber-50 border-l-4 border-amber-500 p-4 rounded-r-xl">
             <h4 class="font-bold text-amber-800 mb-2">Lưu ý cực kỳ quan trọng:</h4>
             <ul class="list-disc pl-5 space-y-1 text-amber-900 text-sm">
                 <li>Việc loại hình công ty không hề làm ảnh hưởng tới quyền và lợi ích của công ty nói chung.</li>
                 <li>Mã số thuế của công ty vẫn được giữ nguyên chỉ có sự thay đổi về nội dung hoạt động là thay đổi loại hình.</li>
                 <li>Hóa đơn nếu muốn tiếp tục sử dụng thì quý vị phải liên hệ nhà mạng chữ ký số để thay đổi.</li>
             </ul>
          </div>
        </div>
        
        <div class="bg-primary/5 rounded-2xl p-6 border border-primary/20">
           <img src={imgHoSo.src} alt="Hồ sơ chuyển đổi loại hình doanh nghiệp" class="w-full h-auto mx-auto drop-shadow-md rounded-xl" />
        </div>
      </div>
    </div>
  </section>

  <ProcessSteps 
    title="Quy Trình Chuyển Đổi Tại Hoàng Nam"
    subtitle="Đơn giản, minh bạch và nhanh chóng. Chúng tôi thay bạn thực hiện mọi thủ tục."
    steps={workingProcess} 
  />

  <!-- Chi phí & Lợi ích DV -->
  <section class="py-16 bg-gray-50">
    <div class="container mx-auto px-6 max-w-7xl">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Phí -->
          <div class="bg-white p-8 rounded-2xl shadow-md text-center flex flex-col justify-center">
             <h3 class="text-2xl font-bold text-accent mb-2">Chi Phí Dịch Vụ Của Hoàng Nam</h3>
             <p class="text-gray-600 mb-8">Cam kết không phát sinh bất kỳ khoản phí nào khác.</p>
             
             <div class="text-5xl font-black text-primary mb-2">600K - 1.2 Triệu</div>
             <p class="text-gray-500 font-medium mb-6">Tùy từng loại hình cần chuyển đổi</p>
             
             <div class="inline-block bg-orange-100 text-orange-800 px-4 py-2 rounded-lg font-medium text-sm mb-6 max-w-sm mx-auto">
                 Lệ phí theo quy định nhà nước cấp Đăng ký doanh nghiệp và Báo chí doanh nghiệp: <strong class="text-orange-900">200.000 VNĐ</strong>
             </div>
             
             <p class="text-gray-700 font-medium italic mt-4">Thời gian xử lý: Chỉ <strong class="text-primary text-xl mx-1">3 - 5 ngày</strong> làm việc</p>
          </div>

          <!-- Tại sao chọn -->
          <div>
            <h3 class="text-2xl font-bold text-accent mb-6">Tại sao chọn Hoàng Nam?</h3>
            <div class="space-y-4">
               <ServiceFeature 
                  title="Nhanh chóng & Chính xác" 
                  description="Khi thủ tục chuyển đổi hoàn tất chúng tôi sẽ trả giấy tận nơi theo địa chỉ mà bạn cung cấp. Thông qua đường bưu điện hoặc gửi Grap." 
               />
               <ServiceFeature 
                  title="Đội ngũ chuyên nghiệp" 
                  description="Chúng tôi có đội ngũ nhân viên là các kế toán trưởng, luật sư hỗ trợ làm việc với quy trình làm trọn gói từ A-Z một cách chuyên nghiệp." 
               />
               <ServiceFeature 
                  title="Tiết kiệm & Minh bạch" 
                  description="Rẻ hơn so với việc tự cá nhân bạn đi làm (Chi phí đi lại, tư vấn, khắc dấu… ) mà lại không lo rủi ro." 
               />
               <ServiceFeature 
                  title="Tư vấn toàn diện" 
                  description="Luôn làm việc với tiêu chí tư vấn cho quý khách với chi phí rẻ nhất, tư vấn cách tránh sai sót với cơ quan chi cục Thuế sau này." 
               />
            </div>
            
            <div class="mt-8 text-center sm:text-left">
                <p class="font-bold text-accent mb-4">Bạn chưa rõ vấn đề? Hãy gọi ngay để chúng tôi hỗ trợ!</p>
                <a href="tel:0918883179" class="inline-flex justify-center items-center rounded-lg bg-primary px-8 py-3 text-sm font-semibold text-white shadow-sm hover:bg-primary-dark transition-all hover:-translate-y-1">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                  GỌI NGAY: 091.888.31.79
                </a>
            </div>
          </div>
      </div>
    </div>
  </section>

  <!-- Info Section -->
  <section class="py-16 bg-primary/5">
    <div class="container mx-auto px-6 max-w-4xl text-center">
        <h2 class="text-2xl font-bold text-accent mb-6">Công Ty Tư Vấn Và Kế Toán Hoàng Nam</h2>
        <p class="text-gray-700 mb-8">
            Chúng tôi luôn đồng hành cùng các startup và doanh nghiệp đang hoạt động trên địa bàn để giải quyết các vấn đề Pháp lý & Thuế.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-left">
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100">
                <h4 class="font-bold text-lg text-primary mb-3 border-b border-gray-100 pb-2">Thông Tin Liên Hệ</h4>
                <p class="text-gray-600 mb-2"><strong>Địa chỉ:</strong> 03 Đ. Quản Trọng Hoàng, Xuân Khánh, Ninh Kiều, Cần Thơ, Việt Nam</p>
                <p class="text-gray-600 mb-2"><strong>Điện thoại:</strong> 091.888.31.79</p>
                <p class="text-gray-600"><strong>Email:</strong> tructuyenhoangnam@gmail.com</p>
            </div>
            <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-100 flex flex-col justify-center">
                <h4 class="font-bold text-lg text-primary mb-3 border-b border-gray-100 pb-2">Khu Vực Triển Khai</h4>
                <p class="text-gray-600 text-sm leading-relaxed">Chúng tôi hỗ trợ tận nơi tại Quận Ninh Kiều, Cái Răng, Bình Thủy, Ô Môn, Thốt Nốt và các huyện Phong Điền, Cờ Đỏ, Vĩnh Thạnh, Thới Lai thuộc địa bàn TP Cần Thơ.</p>
            </div>
        </div>
    </div>
  </section>

</BaseLayout>
