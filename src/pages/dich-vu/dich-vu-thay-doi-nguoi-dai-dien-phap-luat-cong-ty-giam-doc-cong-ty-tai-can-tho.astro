---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import CTABanner from "@/components/homepage/CTABanner.astro";
import heroImage from "@/assets/images/services/thay-doi-dai-dien-phap-luat.jpg";

const metadata = {
  title: "Dịch Vụ Thay Đổi Người Đại Diện Pháp Luật, Giám Đốc Công Ty Tại Cần Thơ",
  description:
    "Hoàng Nam cung cấp dịch vụ thay đổi người đại diện pháp luật công ty tại Cần Thơ nhanh chóng, đúng Luật Doanh nghiệp 2020. Xử lý trong 24-48 giờ. Hotline 091.888.31.79.",
};

const changeReasons = [
  { title: "Thay đổi giám đốc công ty", desc: "Người hiện tại không còn phù hợp hoặc không thể tiếp tục đảm nhiệm vai trò." },
  { title: "Chiến lược kinh doanh", desc: "Chỉ định người đại diện mới để phù hợp với định hướng phát triển." },
  { title: "Yêu cầu pháp lý", desc: "Đáp ứng các điều kiện của Luật Doanh nghiệp hoặc cơ quan chức năng." },
];

const penalties = [
  { icon: "⚠️", title: "Phạt hành chính", desc: "Theo Nghị định 122/2021/NĐ-CP, doanh nghiệp có thể bị phạt từ 5-10 triệu đồng nếu không cập nhật thông tin người đại diện pháp luật." },
  { icon: "🏦", title: "Ảnh hưởng giao dịch", desc: "Thông tin không chính xác có thể gây khó khăn khi ký hợp đồng, làm việc với ngân hàng hoặc cơ quan thuế." },
  { icon: "⚖️", title: "Rủi ro pháp lý", desc: "Sai lệch thông tin có thể dẫn đến tranh chấp nội bộ hoặc mất uy tín với đối tác." },
];

const serviceAdvantages = [
  { icon: "⚡", title: "Nhanh chóng", desc: "Hoàn tất thủ tục trong 24-48 giờ thay vì mất hàng tuần tự xử lý." },
  { icon: "💡", title: "Minh bạch", desc: "Báo giá rõ ràng, không phát sinh chi phí ẩn." },
  { icon: "🏆", title: "Chuyên nghiệp", desc: "Đội ngũ chuyên gia pháp lý am hiểu quy trình tại Sở Kế hoạch và Đầu tư Cần Thơ đảm bảo hồ sơ chính xác, đúng luật." },
];

const docsRequired = [
  { name: "Thông báo thay đổi nội dung đăng ký kinh doanh", desc: "Theo mẫu Nghị định 01/2021/NĐ-CP." },
  { name: "Biên bản họp", desc: "Hội đồng thành viên (công ty TNHH) hoặc Đại hội đồng cổ đông (công ty cổ phần) về việc thay đổi người đại diện pháp luật." },
  { name: "Quyết định thay đổi", desc: "Do chủ sở hữu/Hội đồng quản trị ban hành." },
  { name: "Thông tin đại diện pháp luật mới", desc: "Bản sao CMND/CCCD/hộ chiếu công chứng, lý lịch tư pháp (nếu cần)." },
  { name: "Giấy chứng nhận đăng ký doanh nghiệp", desc: "Bản sao công chứng." },
  { name: "Giấy ủy quyền", desc: "Nếu sử dụng dịch vụ của Hoàng Nam." },
];

const legalRequirements = [
  "Có năng lực hành vi dân sự đầy đủ.",
  "Không thuộc các đối tượng bị cấm theo Điều 17 Luật Doanh nghiệp 2020 (người đang bị truy cứu trách nhiệm hình sự, công chức nhà nước).",
  "Đảm bảo năng lực hành vi dân sự đầy đủ và không có hạn chế về pháp lý.",
];

const processSteps = [
  {
    title: "Chuẩn bị và nộp hồ sơ",
    items: [
      "Soạn thảo và kiểm tra hồ sơ theo quy định.",
      "Nộp trực tiếp hoặc online qua Cổng thông tin Đăng ký doanh nghiệp quốc gia.",
    ],
  },
  {
    title: "Xử lý tại cơ quan nhà nước",
    items: [
      "Theo dõi tiến độ, xử lý sửa đổi (nếu có) tại Sở KHĐT Cần Thơ.",
    ],
  },
  {
    title: "Nhận kết quả và cập nhật thông tin doanh nghiệp",
    items: [
      "Nhận Giấy chứng nhận đăng ký kinh doanh mới.",
      "Cập nhật thông tin với cơ quan thuế, ngân hàng, và chữ ký số.",
    ],
  },
];

const commitments = [
  { icon: "📋", title: "Báo giá chi tiết", desc: "Minh bạch ngay từ đầu, không phí ẩn." },
  { icon: "🛡️", title: "Hỗ trợ rủi ro pháp lý", desc: "Đảm bảo hồ sơ đúng chuẩn, tránh bị trả lại hoặc phạt hành chính." },
  { icon: "🚀", title: "Bàn giao tận nơi", desc: "Giao Giấy chứng nhận đăng ký kinh doanh mới trực tiếp đến bạn." },
  { icon: "💼", title: "Kết hợp dịch vụ liên quan", desc: "Hỗ trợ cập nhật thuế, chữ ký số, thay đổi địa chỉ sau khi thay đổi người đại diện." },
];

const commonMistakes = [
  "Nộp hồ sơ thiếu giấy tờ: Thiếu biên bản họp, quyết định hoặc thông tin không chính xác.",
  "Không cập nhật hệ thống thuế và ngân hàng: Gây khó khăn trong giao dịch và hóa đơn.",
  "Chậm trễ thông báo: Dẫn đến phạt hành chính hoặc gián đoạn hoạt động kinh doanh.",
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Thay Đổi Người Đại Diện Pháp Luật, Giám Đốc Công Ty Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Trọn Gói – Nhanh 24-48 Giờ – Đúng Luật Doanh Nghiệp 2020
      </p>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Bạn đang tìm <strong class="text-primary">dịch vụ thay đổi người đại diện pháp luật công ty tại Cần Thơ</strong> để đảm bảo hoạt động kinh doanh hợp pháp và không bị gián đoạn? <strong class="text-primary">Hoàng Nam</strong> cung cấp giải pháp trọn gói, giúp bạn hoàn tất <strong>thủ tục thay đổi người đại diện pháp luật tại Cần Thơ</strong> nhanh chóng, đúng quy định <strong>Luật Doanh nghiệp 2020</strong>. Với đội ngũ chuyên gia pháp lý giàu kinh nghiệm, chúng tôi đảm bảo hồ sơ chuẩn khung, xử lý trong 24-48 giờ.
        </p>
      </div>
      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Dịch vụ thay đổi người đại diện pháp luật công ty tại Cần Thơ"
          width={750}
          height={500}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Tại sao cần thay đổi -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Thay Đổi Người Đại Diện Pháp Luật – Giải Pháp Nhanh Chóng, Hợp Pháp
      </h2>
      <h3 class="mt-6 text-xl font-bold text-primary">Tại Sao Cần Thay Đổi Kịp Thời?</h3>
      <div class="mt-4 space-y-3">
        {changeReasons.map((r, i) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">{i + 1}</span>
            <div>
              <strong class="text-primary">{r.title}</strong>
              <span class="text-gray-600">: {r.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <h3 class="mt-8 text-xl font-bold text-primary">Hệ Lụy Nếu Không Thay Đổi Kịp Thời</h3>
      <div class="mt-4 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {penalties.map((p) => (
          <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
            <div class="mb-3 text-3xl">{p.icon}</div>
            <strong class="block text-sm text-primary">{p.title}</strong>
            <p class="mt-2 text-xs text-gray-600">{p.desc}</p>
          </div>
        ))}
      </div>

      <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {serviceAdvantages.map((a) => (
          <div class="flex items-start gap-3 rounded-xl border border-primary/20 bg-blue-50 p-5">
            <div class="text-2xl">{a.icon}</div>
            <div>
              <strong class="block text-sm text-primary">{a.title}</strong>
              <p class="mt-1 text-xs text-gray-600">{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hồ sơ & Quy trình -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Quy Trình Thay Đổi Người Đại Diện Pháp Luật Tại Cần Thơ
      </h2>
      <h3 class="mt-6 text-xl font-bold text-primary">Hồ Sơ Cần Chuẩn Bị</h3>
      <div class="mt-4 space-y-3">
        {docsRequired.map((doc) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-gray-50 p-5 shadow-sm">
            <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-primary" />
            <div>
              <strong class="text-primary">{doc.name}</strong>
              <span class="text-gray-600">: {doc.desc}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-4 rounded-r-xl border-l-[6px] border-blue-400 bg-blue-50 px-6 py-4">
        <p class="text-sm text-blue-800">
          <strong>Yêu cầu tư cách pháp lý:</strong> Người đại diện pháp luật mới phải:
        </p>
        <ul class="mt-2 space-y-1">
          {legalRequirements.map((r) => (
            <li class="flex items-start gap-2 text-sm text-blue-800">
              <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-blue-400" />{r}
            </li>
          ))}
        </ul>
      </div>

      <h3 class="mt-8 text-xl font-bold text-primary">Các Bước Thực Hiện</h3>
      <div class="mt-4 flex flex-col gap-5">
        {processSteps.map((step, i) => (
          <div class="flex items-start gap-5 rounded-xl border border-gray-100 bg-gray-50 p-6 shadow-sm">
            <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {i + 1}
            </span>
            <div>
              <h4 class="font-bold text-primary">{step.title}</h4>
              <ul class="mt-2 space-y-1 text-gray-600">
                {step.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary/50" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 rounded-xl border border-blue-200 bg-blue-50 p-5">
        <p class="text-sm text-blue-800">
          ⏱️ <strong>Thời gian xử lý:</strong> 3-5 ngày tại Sở KHĐT Cần Thơ. Dịch vụ Hoàng Nam: <strong>24-48 giờ</strong>.<br />
          💰 <strong>Chi phí:</strong> Lệ phí nhà nước <strong>200.000 đ</strong> + Phí dịch vụ <strong>500.000 – 1.000.000 đ</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- Cam kết -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Cam Kết Của Hoàng Nam
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
        {commitments.map((c) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:shadow-md">
            <div class="text-3xl">{c.icon}</div>
            <div>
              <strong class="block text-primary">{c.title}</strong>
              <p class="mt-1 text-sm text-gray-600">{c.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sai lầm & Case study -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Các Sai Lầm Phổ Biến Cần Tránh
      </h2>
      <div class="mt-6 space-y-3">
        {commonMistakes.map((m) => (
          <div class="flex items-start gap-3 rounded-xl border border-red-100 bg-red-50 p-4">
            <span class="font-bold text-red-500">!</span>
            <p class="text-sm text-red-800">{m}</p>
          </div>
        ))}
      </div>
      <div class="mt-8 rounded-2xl border border-green-200 bg-green-50 p-6">
        <h3 class="font-bold text-green-800">✅ Câu Chuyện Thực Tế</h3>
        <p class="mt-2 text-sm text-gray-700">
          Một công ty TNHH tại Cần Thơ gặp khó khăn khi giám đốc cũ chuyển công tác. Hồ sơ tự nộp bị trả lại 2 lần vì thiếu giấy tờ. Hoàng Nam đã tư vấn, soạn thảo hồ sơ chuẩn khung, nộp và theo dõi tại Sở KHĐT Cần Thơ, hoàn tất trong <strong>24 giờ</strong>. Kết quả: Doanh nghiệp tiết kiệm thời gian, tránh phạt hành chính và duy trì uy tín với đối tác.
        </p>
      </div>
    </div>
  </section>

  <!-- Khu vực hỗ trợ -->
  <section class="bg-gray-50 py-12">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border-2 border-dashed border-primary bg-blue-50 p-8 text-center">
        <p class="text-lg font-bold text-primary">
          📍 Hỗ trợ tận nơi tại Cần Thơ:{" "}
          <span class="font-normal text-gray-700">
            Ninh Kiều, Cái Răng, Bình Thủy, Ô Môn, Thốt Nốt, Phong Điền, Cờ Đỏ, Vĩnh Thạnh, Thới Lai.
          </span>
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border border-primary/20 bg-blue-50 p-8">
        <h2 class="text-xl font-extrabold text-primary">
          📞 Gọi Ngay Hotline 091.888.31.79 – Hoàn Tất Thủ Tục Thay Đổi Người Đại Diện Pháp Luật Trong 24H!
        </h2>
        <div class="mt-6 space-y-2 text-sm text-gray-700">
          <p>📌 <strong>Địa chỉ:</strong> 462 Lê Hồng Nhi, KV1, P. Ba Láng, Q. Cái Răng, Tp. Cần Thơ</p>
          <p>📞 <strong>Hotline:</strong> 091.888.31.79</p>
          <p>📧 <strong>Email:</strong> <a href="mailto:tructuyenhoangnam@gmail.com" class="text-primary underline">tructuyenhoangnam@gmail.com</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Gọi Ngay 091.888.31.79 – Thay Đổi Người Đại Diện Pháp Luật Trong 24H!"
    subtitle="Hoàng Nam – Gỡ rối, kết nối, đảm bảo thông suốt mọi thủ tục pháp lý doanh nghiệp tại Cần Thơ."
  />
</BaseLayout>
