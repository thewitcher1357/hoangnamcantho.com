---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import CTABanner from "@/components/homepage/CTABanner.astro";
import heroImage from "@/assets/images/services/thay-doi-co-dong.jpg";
import stepsImage from "@/assets/images/services/so-ke-hoach-dau-tu-steps2.png";

const metadata = {
  title: "Dịch Vụ Thay Đổi Cổ Đông Công Ty Cổ Phần Tại Cần Thơ – 3-5 Ngày",
  description:
    "Hoàng Nam cung cấp dịch vụ thay đổi cổ đông công ty cổ phần tại Cần Thơ trọn gói. Chuyển nhượng cổ phần, thêm cổ đông mới. Nhanh 3-5 ngày, đúng Luật Doanh nghiệp 2020. Hotline 091.888.31.79.",
};

const changeReasons = [
  { title: "Chuyển nhượng cổ phần", desc: "Cổ đông hiện tại chuyển nhượng cổ phần cho cá nhân/tổ chức khác, thay đổi tỷ lệ sở hữu." },
  { title: "Thêm hoặc giảm cổ đông", desc: "Công ty tiếp nhận cổ đông mới hoặc cổ đông hiện tại rút vốn." },
  { title: "Thay đổi cổ đông sáng lập", desc: "Điều chỉnh thông tin cổ đông sáng lập theo yêu cầu chiến lược hoặc pháp lý." },
  { title: "Tái cấu trúc doanh nghiệp", desc: "Thay đổi cổ đông để phù hợp với kế hoạch mở rộng hoặc tái định hướng kinh doanh." },
];

const penalties = [
  { icon: "⚠️", title: "Phạt hành chính", desc: "Theo Nghị định 122/2021/NĐ-CP, doanh nghiệp có thể bị phạt từ 5-10 triệu đồng nếu không cập nhật thông tin cổ đông." },
  { icon: "⚖️", title: "Rủi ro pháp lý", desc: "Thông tin cổ đông không chính xác có thể ảnh hưởng đến quyền biểu quyết, phân chia lợi nhuận hoặc giao dịch với cơ quan thuế." },
  { icon: "📊", title: "Tác động đến cấu trúc vốn", desc: "Sai lệch thông tin cổ đông có thể làm mất cân bằng tỷ lệ vốn điều lệ, gây tranh chấp nội bộ." },
];

const processSteps = [
  {
    title: "Họp Đại hội đồng cổ đông",
    items: [
      "Tổ chức họp để thông qua quyết định thay đổi cổ đông hoặc chuyển nhượng cổ phần.",
      "Soạn biên bản họp và nghị quyết theo mẫu chuẩn.",
    ],
  },
  {
    title: "Chuẩn bị hồ sơ",
    items: [
      "Soạn thảo thông báo thay đổi nội dung đăng ký kinh doanh.",
      "Chuẩn bị hợp đồng chuyển nhượng cổ phần (nếu có).",
    ],
  },
  {
    title: "Nộp hồ sơ tại Sở KHĐT Cần Thơ",
    items: [
      "Nộp trực tiếp hoặc online qua Cổng thông tin Đăng ký doanh nghiệp quốc gia.",
      "Theo dõi và xử lý sửa đổi (nếu cần).",
    ],
  },
  {
    title: "Nhận kết quả",
    items: [
      "Nhận Giấy chứng nhận đăng ký kinh doanh cập nhật trong 3-5 ngày làm việc.",
    ],
  },
];

const docsRequired = [
  "Thông báo thay đổi nội dung đăng ký kinh doanh (theo mẫu Nghị định 01/2021/NĐ-CP).",
  "Biên bản họp Đại hội đồng cổ đông: quyết định thay đổi cổ đông hoặc chuyển nhượng cổ phần.",
  "Hợp đồng chuyển nhượng cổ phần: công chứng nếu pháp luật yêu cầu.",
  "Danh sách cổ đông mới: cập nhật thông tin cổ đông và tỷ lệ sở hữu.",
  "Giấy chứng nhận đăng ký doanh nghiệp: bản sao công chứng.",
  "Giấy ủy quyền (nếu sử dụng dịch vụ của Hoàng Nam).",
];

const serviceFeatures = [
  { icon: "⏱️", title: "Tiết kiệm thời gian", desc: "Hoàn tất thủ tục trong 3-5 ngày, thay vì mất hàng tuần tự xử lý." },
  { icon: "📋", title: "Tránh sai sót", desc: "Hồ sơ được soạn thảo chuẩn khung, đảm bảo không bị trả lại." },
  { icon: "⚖️", title: "Tuân thủ pháp luật", desc: "Đáp ứng mọi yêu cầu của pháp luật doanh nghiệp và Sở Kế hoạch và Đầu tư Cần Thơ." },
  { icon: "📞", title: "Hỗ trợ kế toán", desc: "Tư vấn đồng bộ về thuế và các vấn đề liên quan sau thay đổi." },
];

const relatedServices = [
  { title: "Tăng Giảm Vốn Điều Lệ CTCP", items: ["Soạn hồ sơ điều chỉnh vốn theo tỷ lệ sở hữu mới.", "Tư vấn mức vốn phù hợp với chiến lược kinh doanh.", "Xử lý đồng bộ thuế môn bài, công bố thông tin."] },
  { title: "Thay Đổi Đại Diện Pháp Luật / Đăng Ký Kinh Doanh", items: ["Cập nhật thông tin đại diện pháp luật tại Sở KHĐT Cần Thơ.", "Đảm bảo tính nhất quán trên Giấy chứng nhận đăng ký kinh doanh."] },
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Thay Đổi Cổ Đông Công Ty Cổ Phần Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Nhanh 3-5 Ngày – Trọn Gói – Đúng Luật Doanh Nghiệp 2020
      </p>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Bạn đang cần <strong class="text-primary">dịch vụ thay đổi cổ đông công ty cổ phần tại Cần Thơ</strong> để chuyển nhượng cổ phần, thêm cổ đông mới hay điều chỉnh cấu trúc vốn? <strong class="text-primary">Hoàng Nam</strong> cung cấp giải pháp trọn gói, giúp bạn hoàn tất <strong>thủ tục thay đổi cổ đông công ty cổ phần Cần Thơ</strong> nhanh chóng, đúng quy định <strong>Luật Doanh nghiệp 2020</strong>.
        </p>
      </div>
      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Dịch Vụ Thay Đổi Cổ Đông Công Ty Cổ Phần tại Cần Thơ"
          width={750}
          height={500}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Khi nào cần thay đổi cổ đông -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Thay Đổi Cổ Đông Công Ty Cổ Phần – Khi Nào Cần?
      </h2>
      <div class="mt-6 space-y-3">
        {changeReasons.map((r, i) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">{i + 1}</span>
            <div>
              <strong class="text-primary">{r.title}</strong>
              <span class="text-gray-600">: {r.desc}</span>
            </div>
          </div>
        ))}
      </div>

      <h3 class="mt-8 text-xl font-bold text-primary">Hệ Lụy Nếu Không Thực Hiện Kịp Thời</h3>
      <div class="mt-4 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {penalties.map((p) => (
          <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
            <div class="mb-3 text-3xl">{p.icon}</div>
            <strong class="block text-sm text-primary">{p.title}</strong>
            <p class="mt-2 text-xs text-gray-600">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quy trình -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Quy Trình Thay Đổi Cổ Đông Công Ty Cổ Phần Tại Cần Thơ
      </h2>
      <div class="my-8 overflow-hidden rounded-2xl shadow-md">
        <Image
          src={stepsImage}
          alt="Các Bước Thực Hiện Tại Sở Kế Hoạch Đầu Tư Cần Thơ"
          width={1099}
          height={552}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
      <div class="flex flex-col gap-5">
        {processSteps.map((step, i) => (
          <div class="flex items-start gap-5 rounded-xl border border-gray-100 bg-gray-50 p-6 shadow-sm">
            <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {i + 1}
            </span>
            <div>
              <h4 class="font-bold text-primary">{step.title}</h4>
              <ul class="mt-2 space-y-1 text-gray-600">
                {step.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary/50" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hồ sơ -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h3 class="text-xl font-bold text-primary">Hồ Sơ Cần Chuẩn Bị Để Thay Đổi Cổ Đông</h3>
      <div class="mt-4 space-y-3">
        {docsRequired.map((doc) => (
          <div class="flex items-start gap-3 rounded-xl border border-gray-100 bg-white p-4 shadow-sm">
            <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-primary" />
            <p class="text-sm text-gray-700">{doc}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 rounded-xl border border-blue-200 bg-blue-50 p-5">
        <p class="text-sm text-blue-800">
          💰 <strong>Chi phí tham khảo:</strong> Lệ phí nhà nước <strong>200.000 đ</strong> + Phí dịch vụ <strong>700.000 – 1.500.000 đ</strong> (tùy mức độ phức tạp).
        </p>
      </div>
    </div>
  </section>

  <!-- Lợi ích dịch vụ -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Lợi Ích Khi Chọn Hoàng Nam
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
        {serviceFeatures.map((f) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-gray-50 p-6 shadow-sm transition-all hover:shadow-md">
            <div class="text-3xl">{f.icon}</div>
            <div>
              <strong class="block text-primary">{f.title}</strong>
              <p class="mt-1 text-sm text-gray-600">{f.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Dịch vụ liên quan -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Các Dịch Vụ Liên Quan Đến Thay Đổi Cổ Đông
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
        {relatedServices.map((svc) => (
          <div class="rounded-2xl border-l-[5px] border-primary bg-white p-6 shadow-sm">
            <h4 class="font-bold text-primary">{svc.title}</h4>
            <ul class="mt-3 space-y-2 text-sm text-gray-600">
              {svc.items.map((item) => (
                <li class="flex items-start gap-2">
                  <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary/50" />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Khu vực hỗ trợ -->
  <section class="bg-white py-12">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border-2 border-dashed border-primary bg-blue-50 p-8 text-center">
        <p class="text-lg font-bold text-primary">
          📍 Hỗ trợ tận nơi tại Cần Thơ:{" "}
          <span class="font-normal text-gray-700">
            Ninh Kiều, Cái Răng, Bình Thủy, Ô Môn, Thốt Nốt, Phong Điền, Cờ Đỏ, Vĩnh Thạnh, Thới Lai.
          </span>
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border border-primary/20 bg-blue-50 p-8">
        <h2 class="text-xl font-extrabold text-primary">
          📞 Gọi Ngay Hotline 091.888.31.79 – Tư Vấn Miễn Phí và Xử Lý Hồ Sơ Thay Đổi Cổ Đông Trong 3-5 Ngày!
        </h2>
        <div class="mt-6 space-y-2 text-sm text-gray-700">
          <p>📌 <strong>Địa chỉ:</strong> 462 Lê Hồng Nhi, KV1, P. Ba Láng, Q. Cái Răng, Tp. Cần Thơ</p>
          <p>📞 <strong>Hotline:</strong> 091.888.31.79</p>
          <p>📧 <strong>Email:</strong> <a href="mailto:tructuyenhoangnam@gmail.com" class="text-primary underline">tructuyenhoangnam@gmail.com</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Gọi Ngay 091.888.31.79 – Thay Đổi Cổ Đông CTCP Trong 3-5 Ngày!"
    subtitle="Hoàng Nam – Gỡ rối, kết nối, đảm bảo thông suốt mọi thủ tục pháp lý doanh nghiệp tại Cần Thơ."
  />
</BaseLayout>
