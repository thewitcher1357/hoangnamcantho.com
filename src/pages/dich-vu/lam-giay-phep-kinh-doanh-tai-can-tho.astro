---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { siteConfig } from "@/config/site";
import CTABanner from "@/components/homepage/CTABanner.astro";
import heroImage from "@/assets/images/services/lam-giay-phep-kinh-doanh.png";

const metadata = {
  title: "Dịch Vụ Làm Giấy Phép Kinh Doanh Tại Cần Thơ – Trọn Gói, Nhanh 3-5 Ngày",
  description:
    "Hoàng Nam cung cấp dịch vụ làm giấy phép kinh doanh tại Cần Thơ trọn gói, nhanh chóng, đúng Luật Doanh nghiệp 2020. Hỗ trợ hơn 2.000 doanh nghiệp. Hotline 091.888.31.79.",
};

const benefits = [
  { icon: "⚡", title: "Tốc độ xử lý nhanh", description: "Hoàn tất thủ tục trong 3-5 ngày làm việc." },
  { icon: "💬", title: "Tư vấn miễn phí", description: "Hỗ trợ lựa chọn loại hình doanh nghiệp phù hợp và các thủ tục sau thành lập." },
  { icon: "💰", title: "Chi phí hợp lý", description: "Báo giá minh bạch, không phát sinh phí ẩn." },
  { icon: "🏆", title: "Uy tín và chuyên nghiệp", description: "Hỗ trợ hơn 2.000 doanh nghiệp tại Cần Thơ và miền Tây." },
];

const businessTypes = [
  "Công ty TNHH một thành viên",
  "Công ty TNHH hai thành viên trở lên",
  "Công ty cổ phần",
  "Doanh nghiệp tư nhân",
  "Hộ kinh doanh cá thể",
  "Công ty có 100% vốn đầu tư nước ngoài",
];

const changeItems = [
  { text: "Thay đổi địa chỉ", detail: "Công ty, chi nhánh, văn phòng đại diện, hoặc địa điểm kinh doanh." },
  { text: "Thay đổi người đại diện pháp luật", detail: "Cập nhật thông tin giám đốc hoặc người đại diện." },
  { text: "Tăng, giảm vốn điều lệ", detail: "Điều chỉnh vốn để phù hợp với chiến lược kinh doanh." },
  { text: "Chuyển nhượng vốn", detail: "Thay đổi tỷ lệ góp vốn hoặc chuyển nhượng cho cá nhân/tổ chức khác." },
  { text: "Chuyển đổi loại hình doanh nghiệp", detail: "Từ TNHH 1TV sang 2TV trở lên, hoặc từ TNHH sang cổ phần." },
  { text: "Bổ sung ngành nghề kinh doanh", detail: "Thêm ngành nghề để mở rộng hoạt động." },
  { text: "Cập nhật CCCD", detail: "Đổi thông tin căn cước công dân cho giám đốc hoặc thành viên công ty." },
];

const processSteps = [
  {
    title: "Tư Vấn và Chuẩn Bị Hồ Sơ",
    items: [
      "Tư vấn miễn phí về loại hình doanh nghiệp, ngành nghề kinh doanh và các quy định pháp lý.",
      "Soạn thảo hồ sơ theo mẫu chuẩn của Sở Kế hoạch và Đầu tư Cần Thơ.",
    ],
  },
  {
    title: "Nộp Hồ Sơ",
    items: [
      "Nộp hồ sơ trực tiếp tại Sở Kế hoạch và Đầu tư Cần Thơ (47 Lê Lai, P. An Hội, Q. Ninh Kiều) hoặc online qua Cổng thông tin Đăng ký doanh nghiệp quốc gia.",
      "Theo dõi tiến trình và xử lý sửa đổi (nếu có).",
    ],
  },
  {
    title: "Nhận Kết Quả và Hoàn Tất Thủ Tục",
    items: [
      "Nhận Giấy chứng nhận đăng ký doanh nghiệp trong 3-5 ngày làm việc.",
      "Khắc con dấu công ty và đăng bố cáo thành lập trên Cổng thông tin quốc gia.",
      "Hỗ trợ nộp tờ khai thuế môn bài và tư vấn các thủ tục sau thành lập.",
    ],
  },
];

const results = [
  "Giấy chứng nhận đăng ký doanh nghiệp (đồng thời là mã số thuế).",
  "Con dấu công ty: dấu tròn chính thức và thông báo mẫu dấu.",
  "Điều lệ công ty chuẩn khung pháp lý.",
  "Hồ sơ nội bộ doanh nghiệp đầy đủ và khoa học.",
];

const afterResults = [
  "Hướng dẫn mở tài khoản ngân hàng, đăng ký chữ ký số, in hóa đơn.",
  "Tư vấn kê khai thuế ban đầu, nộp thuế môn bài, bảo hiểm xã hội.",
  "Xây dựng website, logo, nhãn hiệu và các giấy phép bổ sung (nếu cần).",
];

const commitments = [
  { icon: "💬", text: "Tư vấn miễn phí: Hỗ trợ lựa chọn loại hình doanh nghiệp và ngành nghề phù hợp." },
  { icon: "📋", text: "Soạn thảo hồ sơ chuẩn: Đảm bảo hồ sơ đúng quy định, không bị trả lại." },
  { icon: "🏛️", text: "Đại diện nộp hồ sơ: Làm việc trực tiếp với Sở Kế hoạch và Đầu tư Cần Thơ." },
  { icon: "🛵", text: "Giao kết quả tận nơi: Nhận giấy phép và con dấu tại địa chỉ khách hàng yêu cầu." },
  { icon: "🤝", text: "Hỗ trợ sau thành lập: Tư vấn các thủ tục thuế, hóa đơn điện tử, và bảo hiểm xã hội." },
];

const supportAreas = [
  "Ninh Kiều", "Cái Răng", "Bình Thủy", "Ô Môn", "Thốt Nốt",
  "Phong Điền", "Cờ Đỏ", "Vĩnh Thạnh", "Thới Lai",
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Làm Giấy Phép Kinh Doanh Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Trọn gói – Nhanh 3-5 ngày – Đúng Luật Doanh nghiệp 2020
      </p>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Bạn đang muốn thành lập doanh nghiệp hoặc cần <strong class="text-primary">dịch vụ làm giấy phép kinh doanh tại Cần Thơ</strong> để khởi đầu hoạt động kinh doanh một cách hợp pháp? <strong class="text-primary">Hoàng Nam</strong> tự hào là đơn vị hàng đầu cung cấp dịch vụ đăng ký kinh doanh và <strong>thay đổi nội dung đăng ký kinh doanh</strong> tại Cần Thơ và khu vực miền Tây. Với hơn 5 năm kinh nghiệm và hỗ trợ thành công cho hơn 2.000 doanh nghiệp, chúng tôi cam kết mang đến giải pháp nhanh chóng, chuyên nghiệp, đúng quy định <strong>Luật Doanh nghiệp 2020</strong>.
        </p>
      </div>

      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Dịch vụ làm giấy phép kinh doanh tại Cần Thơ"
          width={815}
          height={545}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Tại Sao Chọn Hoàng Nam -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <h2 class="text-center text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Tại Sao Chọn Dịch Vụ Của Hoàng Nam?
      </h2>
      <p class="mt-4 text-center text-lg text-gray-600">
        Dịch vụ trọn gói giúp bạn tiết kiệm thời gian, công sức và đảm bảo tuân thủ pháp luật.
      </p>
      <div class="mt-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {benefits.map((b) => (
          <div class="group rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
            <div class="mb-3 text-3xl">{b.icon}</div>
            <strong class="block text-lg text-primary">{b.title}</strong>
            <p class="mt-2 text-sm text-gray-600">{b.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Loại Hình Kinh Doanh -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Các Loại Hình Kinh Doanh Bạn Có Thể Đăng Ký
      </h2>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {businessTypes.map((type) => (
          <div class="flex items-center gap-3 rounded-lg border border-gray-100 bg-white p-4 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span class="text-gray-700">{type}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Nội dung thay đổi GPKD -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Các Nội Dung Thay Đổi Trên Giấy Phép Kinh Doanh
      </h2>
      <p class="mt-4 text-gray-600">
        Ngoài việc hỗ trợ đăng ký mới, Hoàng Nam cung cấp <a href="/dich-vu/thay-doi-giay-phep-kinh-doanh-tai-can-tho" class="font-bold text-primary hover:underline">dịch vụ thay đổi giấy phép kinh doanh tại Cần Thơ</a>, bao gồm:
      </p>
      <div class="mt-6 space-y-4">
        {changeItems.map((item) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
            <div>
              <strong class="text-primary">{item.text}</strong>
              <span class="text-gray-600">: {item.detail}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Quy Trình -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Quy Trình Đăng Ký Giấy Phép Kinh Doanh Tại Cần Thơ
      </h2>
      <div class="mt-10 flex flex-col gap-6">
        {processSteps.map((step, index) => (
          <div class="flex items-start gap-5 rounded-xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:shadow-md">
            <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {index + 1}
            </span>
            <div>
              <h3 class="text-lg font-bold text-primary">{step.title}</h3>
              <ul class="mt-2 space-y-1 text-gray-600">
                {step.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary/50" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hồ Sơ Cần Thiết -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Hồ Sơ Làm Giấy Phép Đăng Ký Kinh Doanh
      </h2>
      <div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-2">
        <!-- Hộ cá thể -->
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
          <h3 class="mb-4 text-lg font-bold text-primary">Hồ Sơ Cho Hộ Kinh Doanh Cá Thể</h3>
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><strong>Đơn đề nghị đăng ký hộ kinh doanh:</strong> Theo mẫu chuẩn.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><strong>Bản sao CCCD/CMND:</strong> Công chứng, hợp lệ của chủ hộ kinh doanh.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><strong>Hợp đồng thuê mặt bằng:</strong> Công chứng (nếu thuê địa điểm kinh doanh).</span>
            </li>
          </ul>
        </div>
        <!-- Doanh nghiệp -->
        <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
          <h3 class="mb-4 text-lg font-bold text-primary">Hồ Sơ Cho Doanh Nghiệp</h3>
          <ul class="space-y-4 text-gray-700">
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><strong>Đơn đề nghị đăng ký doanh nghiệp:</strong> Theo mẫu của Sở KH&ĐT.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><strong>Dự thảo điều lệ công ty:</strong> Có chữ ký xác nhận của các thành viên góp vốn.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><strong>Danh sách thành viên/cổ đông:</strong> Tùy loại hình (TNHH, cổ phần, hợp danh).</span>
            </li>
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span><strong>Bản sao CCCD/CMND/hộ chiếu:</strong> Công chứng của người đại diện và thành viên góp vốn.</span>
            </li>
          </ul>
        </div>
      </div>
      <div class="mt-6 rounded-r-xl border-l-[6px] border-amber-400 bg-amber-50 px-6 py-4">
        <p class="text-sm text-amber-800">
          <strong>Lưu ý:</strong> Hồ sơ cần được chuẩn bị đầy đủ, đúng quy định <strong>Luật Doanh nghiệp 2020</strong> và <strong>Nghị định 01/2021/NĐ-CP</strong> để tránh bị trả lại.
        </p>
      </div>
    </div>
  </section>

  <!-- Kết quả nhận được -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Kết Quả Khách Hàng Nhận Được
      </h2>
      <div class="mt-8 rounded-2xl border border-gray-200 bg-white p-8 shadow-sm">
        <ul class="space-y-4 text-gray-700">
          {results.map((r) => (
            <li class="flex items-start gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" class="mt-1 h-5 w-5 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              <span>{r}</span>
            </li>
          ))}
        </ul>
        <div class="mt-6 border-t border-gray-100 pt-6">
          <h3 class="mb-3 font-bold text-primary">Hỗ trợ sau thành lập:</h3>
          <ul class="space-y-2 text-gray-600">
            {afterResults.map((r) => (
              <li class="flex items-start gap-2">
                <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary/50" />
                {r}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Dịch Vụ Trọn Gói -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Dịch Vụ Làm Giấy Phép Kinh Doanh Trọn Gói
      </h2>
      <p class="mt-4 text-gray-600">Hoàng Nam cam kết cung cấp dịch vụ với:</p>
      <div class="mt-6 space-y-4">
        {commitments.map((c) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
            <span class="text-2xl">{c.icon}</span>
            <p class="text-gray-700">{c.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tại sao chọn Hoàng Nam -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Tại Sao Chọn Hoàng Nam?
      </h2>
      <div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-3">
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
          <h3 class="mb-3 font-bold text-primary">Chuyên Nghiệp và Uy Tín</h3>
          <ul class="space-y-2 text-sm text-gray-600">
            <li>• Kinh nghiệm hỗ trợ hơn 2.000 doanh nghiệp tại Cần Thơ và miền Tây.</li>
            <li>• Am hiểu quy trình tại Sở KH&ĐT Cần Thơ và các quy định pháp lý.</li>
          </ul>
        </div>
        <div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
