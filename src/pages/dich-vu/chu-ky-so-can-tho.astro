              <!-- Gia hạn - Giá thực thu -->
              <tr class="border-b border-gray-100 hover:bg-blue-50/50">
                <td class="px-3 py-3">GIA HẠN<br/><span class="text-xs font-normal text-gray-500">Giá thực thu</span></td>
                <td class="px-3 py-3 text-center">1,090K</td>
                <td class="px-3 py-3 text-center">1,490K</td>
