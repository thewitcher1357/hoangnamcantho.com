      ],
    },
    {
      label: "GIA HẠN",
      sub: [
        { name: "Giá gốc", fpt: ["1,320K", "2,200K", "2,860K"], vina: ["1,320K", "2,200K", "2,860K"], viettel: ["1,276K", "2,191K", "2,909K"] },
        { name: "Giá thực thu", fpt: ["1,090K", "1,490K", "1,690K"], vina: ["1,150K", "1,490K", "1,690K"], viettel: ["1,090K", "1,690K", "1,890K"] },
      ],
    },
  ],
};

const pricingEASY_NEW = [
  { service: "CẤP MỚI", easy: ["990K", "1,290K", "1,390K", "1,540K"], newca: ["1,090K", "1,390K", "1,490K", "–"] },
  { service: "GIA HẠN", easy: ["–", "–", "–", "–"], newca: ["880K", "1,190K", "1,390K", "–"] },
