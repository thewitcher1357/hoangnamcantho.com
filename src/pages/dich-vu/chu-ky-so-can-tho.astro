const pricingCA2_BKAV = [
  { service: "CẤP MỚI", ca2: ["1,350K", "2,190K", "2,090K"], bkav: ["1,290K", "1,890K", "1,990K"] },
  { service: "GIA HẠN", ca2: ["1,150K", "1,850K", "1,950K"], bkav: ["1,150K", "1,750K", "1,890K"] },
];

const supportAreas = [
  "Ninh Kiều", "Cái Răng", "Bình Thủy", "Ô Môn", "Thốt Nốt",
  "Phong Điền", "Cờ Đỏ", "Vĩnh Thạnh", "Thới Lai",
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Chữ Ký Số Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Gói 4 Năm Chỉ 1.490K – Mua 3 Năm Tặng 1 Năm
      </p>
    </div>
  </section>

  <!-- Khuyến mãi -->
  <section class="bg-white py-10">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl bg-gradient-to-r from-red-500 to-red-600 p-8 text-white text-center shadow-lg">
        <h2 class="text-xl font-bold md:text-2xl">
          🎁 Khuyến mãi 2024: Mua chữ ký số gói 3 năm tặng 1 năm
        </h2>
        <p class="mt-3 text-lg">
          Đặc biệt khi mua gói Hoá Đơn Điện Tử trên 10.000 số sẽ <strong>tặng Chữ Ký Số gói 3 năm</strong>
        </p>
      </div>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-12 md:py-20">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          <strong class="text-primary">Dịch vụ chữ ký số tại Cần Thơ</strong> |Gói 4 năm: 1.490K| của Hoàng Nam
          chuyên hỗ trợ các doanh nghiệp. Đặc biệt đối với những doanh nghiệp mới được thành lập thì việc mua
          chữ ký số (chứng thư số) là điều bắt buộc, bởi vì chữ ký số là một con dấu để xác nhận văn bản là
          của Doanh nghiệp, sử dụng để ký vào những báo cáo, văn bản mà Doanh nghiệp giao dịch, đặc biệt là
          với Cơ quan thuế, Hải quan và Bảo hiểm.
        </p>
      </div>

      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Chữ ký số Cần Thơ"
          width={621}
          height={361}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- CKS là gì -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Chữ Ký Số Là Gì?
      </h2>
      <div class="mt-8 prose prose-lg max-w-none text-gray-700">
        <p class="text-justify">
          Chữ ký số là một dạng chữ ký điện tử được tạo ra bằng sự biến đổi một thông điệp dữ liệu sử dụng
          hệ thống mật mã không đối xứng, theo đó, người có được thông điệp dữ liệu ban đầu và khóa công khai
          của người ký có thể xác định được chính xác:
        </p>
        <div class="mt-4 space-y-3">
          <div class="flex items-start gap-3 rounded-xl bg-blue-50 p-5">
            <span class="font-bold text-primary">a)</span>
            <span>Việc biến đổi nêu trên được tạo ra bằng đúng khóa bí mật tương ứng với khóa công khai trong cùng một cặp khóa.</span>
          </div>
          <div class="flex items-start gap-3 rounded-xl bg-blue-50 p-5">
            <span class="font-bold text-primary">b)</span>
            <span>Sự toàn vẹn nội dung của thông điệp dữ liệu kể từ khi thực hiện việc biến đổi nêu trên.</span>
          </div>
        </div>
        <p class="mt-6 text-justify">
          Chữ ký số hay còn gọi là Token là một thiết bị được mã hóa tất cả các dữ liệu, thông tin của một
          doanh nghiệp dùng thay cho chữ kí trên các loại văn bản và tài liệu số thực hiện đối với các giao dịch
          điện tử qua mạng internet.
        </p>
      </div>
    </div>
  </section>

  <!-- Thông tin CKS -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Thông Tin Có Trong Chữ Ký Số
      </h2>
      <div class="mt-8 space-y-3">
        {cksInfo.map((item) => (
          <div class="flex items-start gap-3 rounded-xl border border-gray-100 bg-white p-4 shadow-sm">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="text-gray-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CKS đối với DN -->
  <section class="bg-gray-50 py-16 md:py-24">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Chữ Ký Số Đối Với Doanh Nghiệp
      </h2>
      <div class="mt-8 space-y-4">
        {cksUsages.map((item) => (
          <div class="flex items-start gap-3 rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-all hover:shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-6 w-6 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-gray-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Bảng giá FPT/VINA/VIETTEL -->
  <section class="bg-white py-16 md:py-24">
    <div class="mx-auto max-w-6xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Bảng Giá Chữ Ký Số – FPT, VINA, VIETTEL
      </h2>
      <div class="mt-8 overflow-hidden rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="overflow-x-auto">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="bg-primary text-white">
                <th class="px-3 py-3 font-bold" rowspan="2">Dịch vụ</th>
                <th class="px-3 py-3 font-bold text-center" colspan="3">FPT-CA</th>
                <th class="px-3 py-3 font-bold text-center" colspan="3">VINA-CA</th>
                <th class="px-3 py-3 font-bold text-center" colspan="3">VIETTEL-CA</th>
              </tr>
              <tr class="bg-primary/90 text-white text-xs">
