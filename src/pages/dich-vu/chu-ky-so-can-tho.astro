                <td class="px-3 py-3 text-center">1,250K</td>
                <td class="px-3 py-3 text-center">1,650K</td>
                <td class="px-3 py-3 text-center">1,750K</td>
                <td class="px-3 py-3 text-center">1,350K</td>
                <td class="px-3 py-3 text-center">1,750K</td>
                <td class="px-3 py-3 text-center">1,890K</td>
                <td class="px-3 py-3 text-center">1,290K</td>
                <td class="px-3 py-3 text-center">1,790K</td>
                <td class="px-3 py-3 text-center">1,990K</td>
