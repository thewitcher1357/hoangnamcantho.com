---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import CTABanner from "@/components/homepage/CTABanner.astro";
import heroImage from "@/assets/images/services/thay-doi-cccd-gpkd.jpg";
import hoSoImage from "@/assets/images/services/ho-so-cap-nhat-cccd.png";

const metadata = {
  title: "Dịch Vụ Thay Đổi CCCD Trên Giấy Phép Kinh Doanh Tại Cần Thơ – 24H",
  description:
    "Hoàng Nam cung cấp dịch vụ thay đổi CCCD trên giấy phép kinh doanh tại Cần Thơ nhanh chóng, đúng quy định Luật Doanh nghiệp 2020. Xử lý trong 24-48 giờ. Hotline 091.888.31.79.",
};

const risks = [
  { icon: "⚠️", title: "Phạt hành chính", desc: "Theo Nghị định 01/2021/NĐ-CP, doanh nghiệp có thể bị phạt từ 1-3 triệu đồng nếu không thông báo thay đổi thông tin." },
  { icon: "🏦", title: "Rắc rối giao dịch", desc: "Thông tin không khớp gây khó khăn khi làm việc với ngân hàng, xuất hóa đơn, hoặc ký hợp đồng." },
  { icon: "📉", title: "Ảnh hưởng uy tín", desc: "Sai lệch thông tin làm giảm độ tin cậy của doanh nghiệp với đối tác và khách hàng." },
];

const whyUpdate = [
  "Luật Doanh nghiệp 2020 yêu cầu thông tin người đại diện pháp luật trên giấy phép kinh doanh phải chính xác.",
  "Khi chuyển từ chứng minh nhân dân cũ sang CCCD gắn chip, doanh nghiệp phải cập nhật để tránh rủi ro pháp lý.",
  "Thông tin chính xác giúp duy trì giao dịch với ngân hàng, cơ quan thuế, và đối tác.",
];

const docsRequired = [
  { name: "Mẫu phụ lục II-5", desc: "Theo Thông tư 01/2021/TT-BKHĐT, thông báo thay đổi nội dung đăng ký doanh nghiệp." },
  { name: "Bản sao CCCD gắn chip", desc: "Công chứng của người đại diện pháp luật." },
  { name: "Giấy chứng nhận đăng ký doanh nghiệp", desc: "Bản sao công chứng." },
  { name: "Quyết định thay đổi", desc: "Do chủ sở hữu/Hội đồng quản trị ban hành (nếu cần)." },
  { name: "Giấy ủy quyền", desc: "Nếu sử dụng dịch vụ của Hoàng Nam." },
];

const processSteps = [
  {
    title: "Chuẩn bị và kiểm tra hồ sơ",
    items: [
      "Soạn thảo mẫu phụ lục thay đổi CCCD và các giấy tờ liên quan.",
      "Kiểm tra tính hợp lệ của CCCD và thông tin doanh nghiệp.",
    ],
  },
  {
    title: "Nộp hồ sơ tại Sở Kế hoạch và Đầu tư Cần Thơ",
    items: [
      "Nộp trực tiếp tại Sở KHĐT Cần Thơ (số 47 Lê Lai, P. An Hội, Q. Ninh Kiều) hoặc online qua Cổng thông tin Đăng ký doanh nghiệp quốc gia.",
      "Theo dõi và xử lý sửa đổi (nếu có).",
    ],
  },
  {
    title: "Nhận kết quả",
    items: [
      "Nhận Giấy chứng nhận đăng ký doanh nghiệp cập nhật trong 3-5 ngày làm việc.",
      "Cập nhật thông tin với cơ quan thuế, ngân hàng, và chữ ký số (nếu cần).",
    ],
  },
];

const benefits = [
  { icon: "⚡", title: "Quy trình chuyên nghiệp", desc: "Xử lý hồ sơ nhanh trong 24-48 giờ, đúng quy định Luật Doanh nghiệp." },
  { icon: "💬", title: "Tư vấn miễn phí", desc: "Đội ngũ chuyên gia tại Cần Thơ hỗ trợ tận tâm, giải đáp mọi thắc mắc." },
  { icon: "✅", title: "Cam kết đúng luật", desc: "Đảm bảo hồ sơ chuẩn khung, tránh sai sót hoặc bị trả lại." },
  { icon: "💰", title: "Chi phí hợp lý", desc: "Minh bạch, không phát sinh thêm phí, phù hợp với doanh nghiệp tại Cần Thơ." },
];

const commonMistakes = [
  "Nộp hồ sơ thiếu giấy tờ: Thiếu mẫu phụ lục II-5 hoặc bản sao CCCD công chứng.",
  "Không cập nhật hệ thống thuế/ngân hàng: Gây khó khăn trong giao dịch và xuất hóa đơn.",
  "Chậm trễ thông báo: Dẫn đến phạt hành chính hoặc gián đoạn hoạt động kinh doanh.",
];
---

<BaseLayout {metadata}>
  <!-- Hero Banner -->
  <section class="relative bg-gradient-to-r from-primary to-primary-light py-20 text-center text-white md:py-28">
    <div class="relative z-10 mx-auto max-w-4xl px-6">
      <h1 class="text-3xl font-extrabold uppercase leading-tight drop-shadow-md md:text-5xl">
        Dịch Vụ Thay Đổi CCCD Trên Giấy Phép Kinh Doanh Tại Cần Thơ
      </h1>
      <p class="mt-5 text-lg font-light text-white/90 md:text-xl">
        Nhanh 24-48 giờ – Đúng Luật – Không Lo Sai Sót
      </p>
    </div>
  </section>

  <!-- Giới thiệu -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="prose prose-lg mx-auto max-w-none text-gray-700">
        <p class="text-justify">
          Cần <strong class="text-primary">thay đổi CCCD trên giấy phép kinh doanh tại Cần Thơ</strong> để đảm bảo thông tin doanh nghiệp hợp pháp và tránh rủi ro pháp lý? <strong class="text-primary">Hoàng Nam</strong> cung cấp dịch vụ trọn gói, giúp bạn hoàn tất <strong>thủ tục đổi CCCD trên giấy phép kinh doanh</strong> nhanh chóng, đúng quy định <strong>Luật Doanh nghiệp 2020</strong>. Với đội ngũ chuyên gia pháp lý giàu kinh nghiệm tại Cần Thơ, chúng tôi đảm bảo hồ sơ chuẩn khung, xử lý trong 24-48 giờ.
        </p>
      </div>
      <div class="my-10 overflow-hidden rounded-2xl shadow-xl">
        <Image
          src={heroImage}
          alt="Dịch Vụ Thay Đổi CCCD Trên Giấy Phép Kinh Doanh tại Cần Thơ"
          width={750}
          height={500}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Hậu quả nếu không cập nhật -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Không Cập Nhật CCCD Kịp Thời? Doanh Nghiệp Có Thể Bị Phạt Nặng!
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-3">
        {risks.map((r) => (
          <div class="rounded-xl border border-gray-100 bg-white p-6 text-center shadow-sm">
            <div class="mb-3 text-3xl">{r.icon}</div>
            <strong class="block text-base text-primary">{r.title}</strong>
            <p class="mt-2 text-sm text-gray-600">{r.desc}</p>
          </div>
        ))}
      </div>

      <h3 class="mt-10 text-xl font-bold text-primary">Tại Sao Cần Cập Nhật CCCD Trên Giấy Chứng Nhận Đăng Ký Doanh Nghiệp?</h3>
      <div class="mt-4 space-y-3">
        {whyUpdate.map((item, i) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
            <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-sm font-bold text-primary">{i + 1}</span>
            <p class="text-gray-700">{item}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hồ sơ & Quy trình -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Hướng Dẫn Thủ Tục Thay Đổi CCCD Trên Giấy Phép Kinh Doanh
      </h2>
      <div class="my-8 overflow-hidden rounded-2xl shadow-md">
        <Image
          src={hoSoImage}
          alt="Hồ Sơ Cần Chuẩn Bị Để Cập Nhật CCCD"
          width={987}
          height={521}
          class="w-full object-cover"
          loading="lazy"
        />
      </div>
      <h3 class="mt-6 text-xl font-bold text-primary">Hồ Sơ Cần Chuẩn Bị Để Cập Nhật CCCD</h3>
      <div class="mt-4 space-y-3">
        {docsRequired.map((doc) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-gray-50 p-5 shadow-sm">
            <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-primary" />
            <div>
              <strong class="text-primary">{doc.name}</strong>
              <span class="text-gray-600">: {doc.desc}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-4 rounded-r-xl border-l-[6px] border-amber-400 bg-amber-50 px-6 py-4">
        <p class="text-sm text-amber-800">
          <strong>Lưu ý:</strong> CCCD phải hợp lệ, không thuộc đối tượng bị hạn chế quyền. Hồ sơ cần được kiểm tra kỹ để đảm bảo nộp đúng yêu cầu của Sở Kế hoạch và Đầu tư Cần Thơ.
        </p>
      </div>
    </div>
  </section>

  <!-- Quy trình -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h3 class="text-xl font-bold text-primary">Quy Trình Thay Đổi CCCD Trên Giấy Phép Kinh Doanh</h3>
      <div class="mt-6 flex flex-col gap-5">
        {processSteps.map((step, i) => (
          <div class="flex items-start gap-5 rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
            <span class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-primary text-sm font-bold text-white">
              {i + 1}
            </span>
            <div>
              <h4 class="font-bold text-primary">{step.title}</h4>
              <ul class="mt-2 space-y-1 text-gray-600">
                {step.items.map((item) => (
                  <li class="flex items-start gap-2">
                    <span class="mt-1.5 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-primary/50" />
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-6 rounded-xl border border-blue-200 bg-blue-50 p-5">
        <p class="text-sm text-blue-800">
          ⏱️ <strong>Thời gian xử lý:</strong> Thông thường <strong>3-5 ngày làm việc</strong> tại Sở KHĐT Cần Thơ. Với dịch vụ Hoàng Nam: <strong>24-48 giờ</strong>. Chi phí dịch vụ: <strong>500.000 – 1.000.000 đ</strong> (tùy quy mô). Lệ phí nhà nước: miễn phí hoặc 200.000 đ.
        </p>
      </div>
    </div>
  </section>

  <!-- Lợi ích dịch vụ -->
  <section class="bg-white py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Tại Sao Nên Chọn Dịch Vụ Của Hoàng Nam?
      </h2>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2">
        {benefits.map((b) => (
          <div class="flex items-start gap-4 rounded-xl border border-gray-100 bg-gray-50 p-6 shadow-sm transition-all hover:shadow-md">
            <div class="text-3xl">{b.icon}</div>
            <div>
              <strong class="block text-primary">{b.title}</strong>
              <p class="mt-1 text-sm text-gray-600">{b.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sai lầm thường gặp & Case study -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <h2 class="border-b-[3px] border-primary pb-3 text-2xl font-extrabold uppercase text-primary md:text-3xl">
        Các Sai Lầm Phổ Biến Cần Tránh
      </h2>
      <div class="mt-6 space-y-3">
        {commonMistakes.map((m) => (
          <div class="flex items-start gap-3 rounded-xl border border-red-100 bg-red-50 p-4">
            <span class="text-red-500 font-bold">!</span>
            <p class="text-sm text-red-800">{m}</p>
          </div>
        ))}
      </div>

      <div class="mt-8 rounded-2xl border border-green-200 bg-green-50 p-6">
        <h3 class="font-bold text-green-800">✅ Câu Chuyện Thực Tế</h3>
        <p class="mt-2 text-sm text-gray-700">
          Một công ty TNHH tại Cần Thơ chưa cập nhật CCCD sau khi chuyển từ CMND sang CCCD gắn chip. Hồ sơ tự nộp bị trả lại do thiếu mẫu phụ lục thay đổi CCCD. Hoàng Nam đã kiểm tra, soạn thảo hồ sơ chuẩn khung, nộp tại Sở KHĐT Cần Thơ và nhận kết quả trong <strong>24 giờ</strong> — doanh nghiệp tránh được phạt hành chính và tiếp tục giao dịch bình thường.
        </p>
      </div>
    </div>
  </section>

  <!-- Khu vực hỗ trợ -->
  <section class="bg-white py-12">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border-2 border-dashed border-primary bg-blue-50 p-8 text-center">
        <p class="text-lg font-bold text-primary">
          📍 Hỗ trợ tận nơi tại Cần Thơ:{" "}
          <span class="font-normal text-gray-700">
            Ninh Kiều, Cái Răng, Bình Thủy, Ô Môn, Thốt Nốt, Phong Điền, Cờ Đỏ, Vĩnh Thạnh, Thới Lai.
          </span>
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info -->
  <section class="bg-gray-50 py-10 md:py-14">
    <div class="mx-auto max-w-4xl px-6 lg:px-8">
      <div class="rounded-2xl border border-primary/20 bg-blue-50 p-8">
        <h2 class="text-xl font-extrabold text-primary">
          📞 Gọi Ngay Hotline 091.888.31.79 – Tư Vấn Miễn Phí và Xử Lý Hồ Sơ Trong 24 Giờ!
        </h2>
        <div class="mt-6 space-y-2 text-sm text-gray-700">
          <p>📌 <strong>Địa chỉ:</strong> 462 Lê Hồng Nhi, KV1, P. Ba Láng, Q. Cái Răng, Tp. Cần Thơ</p>
          <p>📞 <strong>Hotline:</strong> 091.888.31.79</p>
          <p>📧 <strong>Email:</strong> <a href="mailto:tructuyenhoangnam@gmail.com" class="text-primary underline">tructuyenhoangnam@gmail.com</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    title="Gọi Ngay 091.888.31.79 – Cập Nhật CCCD Trên GPKD Trong 24 Giờ!"
    subtitle="Hoàng Nam – Gỡ rối, kết nối, đảm bảo thông suốt mọi thủ tục pháp lý doanh nghiệp tại Cần Thơ."
  />
</BaseLayout>
