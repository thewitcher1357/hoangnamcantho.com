---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";
import HeroBanner from "@/components/homepage/HeroBanner.astro";
import ServicesGrid from "@/components/homepage/ServicesGrid.astro";
import CTABanner from "@/components/homepage/CTABanner.astro";
import ProcessSteps from "@/components/homepage/ProcessSteps.astro";
import PricingTable from "@/components/homepage/PricingTable.astro";
import WhyChooseUs from "@/components/homepage/WhyChooseUs.astro";
import RequiredDocs from "@/components/homepage/RequiredDocs.astro";
import LatestPosts from "@/components/homepage/LatestPosts.astro";
import ContactForm from "@/components/homepage/ContactForm.astro";

const metadata = {
  title: `Trang chủ - Dịch vụ tại Cần Thơ`,
  description:
    "Chào mừng bạn đến với website cung cấp dịch vụ chất lượng cao tại Cần Thơ. Thành lập công ty, kế toán, thuế, nhân sự chuyên nghiệp.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <HeroBanner />
  <ServicesGrid />
  <CTABanner />
  <ProcessSteps />
  <PricingTable />
  <WhyChooseUs />
  <RequiredDocs />
  <LatestPosts />
  <ContactForm />
</BaseLayout>
